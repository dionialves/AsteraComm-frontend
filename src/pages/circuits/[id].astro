---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;
const { id } = Astro.params;
---

<Layout>
  <div class="max-w-[1100px] mx-auto">

    <!-- ── 1. Header ──────────────────────────────────────────────────────── -->
    <div class="flex items-start justify-between mb-6">
      <div>
        <nav class="text-xs text-gray-400 mb-1">
          <a href="/circuits" class="underline hover:text-gray-600 transition">Circuitos</a>
          <span class="mx-1">›</span>
          <span id="breadcrumb-code">{id}</span>
        </nav>
        <h1 id="page-title" class="text-xl font-medium text-gray-800">Circuito - {id}</h1>
      </div>
      <div class="flex items-center gap-2 mt-1">
        <button id="btnBack" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition">Voltar</button>
        <button id="btnSave" class="px-4 py-2 bg-[#1D9E75] text-white rounded-lg text-sm font-medium hover:bg-[#178a65] transition">Salvar</button>
      </div>
    </div>

    <!-- Mensagem de feedback -->
    <div id="formMessage" class="hidden mb-4 px-4 py-2 rounded-lg text-sm"></div>

    <!-- ── 2. Card Identificação ──────────────────────────────────────────── -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-4">
      <p class="text-sm font-medium text-gray-700 mb-4">Identificação</p>
      <div class="grid grid-cols-3 gap-4">

        <div>
          <label class="block text-xs text-gray-400 mb-1">ID</label>
          <input id="fieldId" type="text" disabled
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-gray-50 text-gray-400 cursor-not-allowed" />
        </div>

        <div>
          <label class="block text-xs text-gray-400 mb-1">Código</label>
          <input id="fieldNumber" type="text" disabled
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-gray-50 text-gray-400 cursor-not-allowed" />
        </div>

        <div>
          <label class="block text-xs text-gray-400 mb-1">Status</label>
          <div class="flex">
            <button id="btnAtivo" type="button"
              class="flex-1 px-3 py-2 text-sm border border-gray-200 rounded-l-lg text-gray-400 transition">
              Ativo
            </button>
            <button id="btnInativo" type="button"
              class="flex-1 px-3 py-2 text-sm border border-gray-200 border-l-0 rounded-r-lg text-gray-400 transition">
              Inativo
            </button>
          </div>
        </div>

      </div>
    </div>

    <!-- ── 3. Card Autenticação ───────────────────────────────────────────── -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-4">
      <p class="text-sm font-medium text-gray-700 mb-4">Autenticação</p>
      <div class="max-w-xs">
        <label class="block text-xs text-gray-400 mb-1">Senha</label>
        <div class="relative">
          <input id="fieldPassword" type="password" maxlength="10"
            class="w-full px-3 py-2 pr-10 border border-gray-200 rounded-lg text-sm font-mono focus:outline-none focus:ring focus:border-blue-300" />
          <button id="btnTogglePassword" type="button"
            class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition">
            <svg id="iconEye" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg id="iconEyeOff" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 4.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- ── 4. Card Configuração ───────────────────────────────────────────── -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-4">
      <p class="text-sm font-medium text-gray-700 mb-4">Configuração</p>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-xs text-gray-400 mb-1">Tronco <span class="text-red-500">*</span></label>
          <div id="fieldTrunk" class="w-full"></div>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Plano <span class="text-red-500">*</span></label>
          <div id="fieldPlan" class="w-full"></div>
        </div>
      </div>

      <div class="max-w-[400px]">
        <label class="block text-xs text-gray-400 mb-1">Cliente <span class="text-red-500">*</span></label>
        <div id="fieldCustomer" class="w-full"></div>
      </div>
    </div>

    <!-- ── 5. Card DIDs vinculados ────────────────────────────────────────── -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-4">
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm font-medium text-gray-700">DIDs vinculados</p>
        <button id="btnAddDid"
          class="flex items-center gap-1.5 px-3 py-1.5 border border-gray-300 rounded-lg text-xs text-gray-600 hover:bg-gray-50 transition">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Adicionar
        </button>
      </div>

      <div class="border border-gray-200 rounded-lg overflow-hidden">
        <div class="grid bg-gray-50 text-xs font-medium text-gray-400 border-b border-gray-200"
          style="grid-template-columns: 60px 1fr 130px 44px">
          <div class="px-4 py-2">ID</div>
          <div class="px-4 py-2">Número</div>
          <div class="px-4 py-2">Vinculado em</div>
          <div class="px-2 py-2"></div>
        </div>
        <div id="tbody-dids">
          <div class="px-4 py-4 text-center text-sm text-gray-400">Carregando...</div>
        </div>
      </div>
    </div>

    <!-- ── 6. Footer ──────────────────────────────────────────────────────── -->
    <div class="border-t border-gray-200 pt-4 flex items-center justify-between">
      <button id="btnDelete" type="button"
        class="px-4 py-2 border border-gray-200 rounded-lg text-sm text-red-500 hover:bg-red-50 transition">
        Deletar circuito
      </button>
      <span id="footerTimestamp" class="text-xs text-gray-400"></span>
    </div>

  </div>

  <!-- Modal Overlay -->
  <div id="modalOverlay" class="hidden fixed inset-0 bg-black/50 z-40"></div>

  <!-- Modal Vincular DID -->
  <div id="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md">
      <div class="bg-gray-50 flex items-center justify-between px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-sm font-semibold text-gray-800">Vincular DID</h2>
        <div class="flex items-center gap-2">
          <button id="btnModalSave" class="bg-[#1D9E75] text-white rounded-lg px-4 py-2 text-sm font-medium hover:bg-[#178a65] transition">Vincular</button>
          <button id="btnModalCancel" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition">Cancelar</button>
        </div>
      </div>
      <div class="px-6 py-4">
        <div id="modalMessage" class="hidden mb-4 px-4 py-2 rounded-lg text-sm"></div>
        <label class="block text-xs text-gray-400 mb-1">DID disponível <span class="text-red-500">*</span></label>
        <div id="selectDID" class="w-full"></div>
        <p id="semDIDsMsg" class="hidden text-xs text-yellow-600 mt-2">
          Nenhum DID livre disponível. Cadastre em <a href="/dids" class="underline">DIDs</a>.
        </p>
      </div>
    </div>
  </div>

</Layout>

<script type="module" defer>
  import { SearchSelect } from "/src/lib/search-select.ts";

  const circuitId = window.location.pathname.split("/").at(-1);

  const fieldId        = document.getElementById("fieldId");
  const fieldNumber    = document.getElementById("fieldNumber");
  const fieldPassword  = document.getElementById("fieldPassword");
  const formMessage    = document.getElementById("formMessage");
  const didContainer   = document.getElementById("tbody-dids");
  const modal          = document.getElementById("modal");
  const modalOverlay   = document.getElementById("modalOverlay");
  const modalMessage   = document.getElementById("modalMessage");
  const semDIDsMsg     = document.getElementById("semDIDsMsg");
  const footerTs       = document.getElementById("footerTimestamp");
  const btnAtivo       = document.getElementById("btnAtivo");
  const btnInativo     = document.getElementById("btnInativo");
  const btnDelete      = document.getElementById("btnDelete");

  let activeState = true;
  let deleteConfirmPending = false;
  let deleteConfirmTimer = null;

  const ssTrunk    = new SearchSelect(document.getElementById("fieldTrunk"), [], { placeholder: "Selecione um tronco..." });
  const ssCustomer = new SearchSelect(document.getElementById("fieldCustomer"), [], {
    placeholder: "Selecione um cliente...",
    onNavigate: (id) => `customers/${id}`,
  });
  const ssPlan   = new SearchSelect(document.getElementById("fieldPlan"), [], { placeholder: "Selecione um plano..." });
  const ssDID    = new SearchSelect(document.getElementById("selectDID"), [], { placeholder: "Selecione um DID..." });

  // ─── Feedback ────────────────────────────────────────────────────────────────
  function showMessage(text, type) {
    formMessage.textContent = text;
    formMessage.classList.remove("hidden", "bg-green-100", "text-green-700", "bg-red-100", "text-red-700");
    formMessage.classList.add(type === "success" ? "bg-green-100" : "bg-red-100");
    formMessage.classList.add(type === "success" ? "text-green-700" : "text-red-700");
    if (type === "success") setTimeout(() => formMessage.classList.add("hidden"), 3000);
  }

  function showModalMessage(text, type) {
    modalMessage.textContent = text;
    modalMessage.classList.remove("hidden", "bg-green-100", "text-green-700", "bg-red-100", "text-red-700");
    modalMessage.classList.add(type === "success" ? "bg-green-100" : "bg-red-100");
    modalMessage.classList.add(type === "success" ? "text-green-700" : "text-red-700");
  }

  function validatePassword(pw) {
    if (pw.length !== 10)         return "A senha deve ter exatamente 10 caracteres.";
    if (/[^a-zA-Z0-9]/.test(pw)) return "A senha não pode conter caracteres especiais.";
    if (!/[a-z]/.test(pw))        return "A senha deve conter letras minúsculas.";
    if (!/[A-Z]/.test(pw))        return "A senha deve conter letras maiúsculas.";
    if (!/[0-9]/.test(pw))        return "A senha deve conter números.";
    return null;
  }

  function formatNumber(digits) {
    if (!digits || digits.length !== 10) return digits;
    return `(${digits.substring(0, 2)}) ${digits.substring(2, 6)}-${digits.substring(6, 10)}`;
  }

  function formatarData(dataStr) {
    if (!dataStr) return "—";
    return new Date(dataStr).toLocaleDateString("pt-BR", {
      day: "2-digit", month: "2-digit", year: "numeric",
    });
  }

  function formatarDataHora(dataStr) {
    if (!dataStr) return "";
    return new Date(dataStr).toLocaleDateString("pt-BR", {
      day: "2-digit", month: "2-digit", year: "numeric",
      hour: "2-digit", minute: "2-digit",
    });
  }

  // ─── Toggle Status ────────────────────────────────────────────────────────────
  function setActiveState(val) {
    activeState = val;
    if (val) {
      btnAtivo.className   = "flex-1 px-3 py-2 text-sm border rounded-l-lg font-medium transition bg-[#E1F5EE] border-[#1D9E75] text-[#085041]";
      btnInativo.className = "flex-1 px-3 py-2 text-sm border border-gray-200 border-l-0 rounded-r-lg text-gray-400 transition";
    } else {
      btnAtivo.className   = "flex-1 px-3 py-2 text-sm border border-gray-200 rounded-l-lg text-gray-400 transition";
      btnInativo.className = "flex-1 px-3 py-2 text-sm border rounded-r-lg border-l-0 font-medium transition bg-[#FCEBEB] border-[#E24B4A] text-[#791F1F]";
    }
  }

  btnAtivo.addEventListener("click",   () => setActiveState(true));
  btnInativo.addEventListener("click", () => setActiveState(false));

  // ─── Toggle Senha ─────────────────────────────────────────────────────────────
  document.getElementById("btnTogglePassword").addEventListener("click", () => {
    const isPassword = fieldPassword.type === "password";
    fieldPassword.type = isPassword ? "text" : "password";
    document.getElementById("iconEye").classList.toggle("hidden", isPassword);
    document.getElementById("iconEyeOff").classList.toggle("hidden", !isPassword);
  });

  // ─── Carregar selects ─────────────────────────────────────────────────────────
  async function carregarTroncos(selecionado) {
    try {
      const res = await fetch("/api/trunk/trunks");
      const data = await res.json();
      const trunks = data.content || data;
      ssTrunk.setOptions(trunks.map(t => ({ value: t.name, label: `${t.name} (${t.host})` })));
      if (selecionado) ssTrunk.setValue(selecionado);
    } catch { ssTrunk.setOptions([]); }
  }

  async function carregarClientes(selecionado) {
    try {
      const res = await fetch("/api/customer/customers?size=200&sort=name,asc");
      const data = await res.json();
      const customers = data.content || data;
      ssCustomer.setOptions(customers.map(c => ({ value: String(c.id), label: c.name })));
      if (selecionado) ssCustomer.setValue(String(selecionado));
    } catch { ssCustomer.setOptions([]); }
  }

  async function carregarPlanos(selecionado) {
    try {
      const res = await fetch("/api/plan/plans?size=200&sort=name,asc");
      const data = await res.json();
      const plans = data.content || data;
      ssPlan.setOptions(plans.map(p => ({ value: String(p.id), label: p.name })));
      if (selecionado) ssPlan.setValue(String(selecionado));
    } catch { ssPlan.setOptions([]); }
  }

  // ─── Carregar circuito ────────────────────────────────────────────────────────
  async function carregarCircuito() {
    try {
      const res = await fetch(`/api/circuit/${circuitId}`);
      if (!res.ok) { showMessage("Circuito não encontrado.", "error"); return; }
      const c = await res.json();

      fieldId.value       = c.id ?? "";
      fieldNumber.value   = c.number;
      fieldPassword.value = c.password || "";

      document.getElementById("page-title").textContent    = `Circuito - ${c.number}`;
      document.getElementById("breadcrumb-code").textContent = c.number;

      setActiveState(c.active !== false);

      if (c.updatedAt) {
        footerTs.textContent = `Última modificação: ${formatarDataHora(c.updatedAt)}`;
      }

      await Promise.all([
        carregarTroncos(c.trunkName),
        carregarClientes(c.customer?.id ?? null),
        carregarPlanos(c.plan?.id ?? null),
      ]);
    } catch { showMessage("Erro ao carregar circuito.", "error"); }
  }

  // ─── Carregar DIDs ────────────────────────────────────────────────────────────
  async function carregarDIDs() {
    try {
      const res = await fetch(`/api/did/by-circuit/${circuitId}`);
      const vinculados = await res.json();

      didContainer.innerHTML = "";

      if (vinculados.length === 0) {
        didContainer.innerHTML = `<div class="px-4 py-4 text-center text-sm text-gray-400">Nenhum DID vinculado.</div>`;
        return;
      }

      vinculados.forEach((did, idx) => {
        const row = document.createElement("div");
        row.className = `grid items-center text-sm ${idx % 2 === 1 ? "bg-gray-50" : "bg-white"} border-t border-gray-100`;
        row.style.gridTemplateColumns = "60px 1fr 130px 44px";
        row.innerHTML = `
          <div class="px-4 py-2.5 text-xs text-gray-400">${did.id}</div>
          <div class="px-4 py-2.5 font-mono text-gray-700">${formatNumber(did.number)}</div>
          <div class="px-4 py-2.5 text-xs text-gray-400">${formatarData(did.linkedAt ?? did.updatedAt ?? null)}</div>
          <div class="px-2 py-2 flex items-center justify-center">
            <button class="btn-unlink p-1 text-gray-300 hover:text-red-500 transition" title="Desvincular" data-id="${did.id}">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        `;
        row.querySelector(".btn-unlink").addEventListener("click", () => desvinculatDID(did.id));
        didContainer.appendChild(row);
      });
    } catch {
      didContainer.innerHTML = `<div class="px-4 py-4 text-center text-sm text-red-500">Erro ao carregar DIDs.</div>`;
    }
  }

  async function desvinculatDID(didId) {
    if (!confirm("Desvincular este DID?")) return;
    try {
      const res = await fetch("/api/did/unlink", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ didId }),
      });
      if (res.ok) {
        window.showToast?.("DID desvinculado com sucesso!", "success");
        carregarDIDs();
      } else {
        showMessage("Erro ao desvincular DID.", "error");
      }
    } catch { showMessage("Erro ao comunicar com o servidor.", "error"); }
  }

  // ─── Salvar ───────────────────────────────────────────────────────────────────
  document.getElementById("btnSave").addEventListener("click", async () => {
    const password   = fieldPassword.value;
    const trunkName  = ssTrunk.getValue();
    const customerId = ssCustomer.getValue() ? Number(ssCustomer.getValue()) : null;
    const planId     = ssPlan.getValue()     ? Number(ssPlan.getValue())     : null;

    if (!password)  { showMessage("A senha é obrigatória.", "error"); return; }
    const pwErr = validatePassword(password);
    if (pwErr)      { showMessage(pwErr, "error"); return; }
    if (!trunkName) { showMessage("Selecione um tronco.", "error"); return; }
    if (!customerId){ showMessage("Selecione um cliente.", "error"); return; }
    if (!planId)    { showMessage("Selecione um plano.", "error"); return; }

    try {
      const res = await fetch(`/api/circuit/${circuitId}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ password, trunkName, customerId, planId, active: activeState }),
      });
      if (res.ok) {
        const updated = await res.json();
        if (updated.updatedAt) footerTs.textContent = `Última modificação: ${formatarDataHora(updated.updatedAt)}`;
        showMessage("Circuito atualizado com sucesso!", "success");
        window.showToast?.("Circuito atualizado com sucesso!", "success");
      } else {
        const err = await res.text();
        showMessage(err || "Erro ao salvar.", "error");
      }
    } catch { showMessage("Erro ao comunicar com o servidor.", "error"); }
  });

  // ─── Deletar (2 cliques) ──────────────────────────────────────────────────────
  btnDelete.addEventListener("click", async () => {
    if (!deleteConfirmPending) {
      deleteConfirmPending = true;
      btnDelete.textContent = "Tem certeza? Clique novamente";
      btnDelete.className = "px-4 py-2 border border-[#E24B4A] rounded-lg text-sm font-medium text-[#791F1F] bg-[#FCEBEB] transition";
      deleteConfirmTimer = setTimeout(() => {
        deleteConfirmPending = false;
        btnDelete.textContent = "Deletar circuito";
        btnDelete.className = "px-4 py-2 border border-gray-200 rounded-lg text-sm text-red-500 hover:bg-red-50 transition";
      }, 4000);
      return;
    }

    clearTimeout(deleteConfirmTimer);
    deleteConfirmPending = false;

    try {
      const res = await fetch(`/api/circuit/${circuitId}`, { method: "DELETE" });
      if (res.status === 204) {
        window.showToast?.("Circuito excluído com sucesso!", "success");
        window.location.href = "/circuits";
      } else if (res.status === 200) {
        const updated = await res.json();
        setActiveState(updated.active);
        btnDelete.textContent = "Deletar circuito";
        btnDelete.className = "px-4 py-2 border border-gray-200 rounded-lg text-sm text-red-500 hover:bg-red-50 transition";
        showMessage("Circuito possui ligações vinculadas e foi desativado em vez de excluído.", "success");
        window.showToast?.("Circuito desativado.", "success");
      } else {
        const err = await res.json().catch(() => ({}));
        btnDelete.textContent = "Deletar circuito";
        btnDelete.className = "px-4 py-2 border border-gray-200 rounded-lg text-sm text-red-500 hover:bg-red-50 transition";
        showMessage(err.message || "Erro ao excluir circuito.", "error");
      }
    } catch { showMessage("Erro ao comunicar com o servidor.", "error"); }
  });

  // ─── Voltar ───────────────────────────────────────────────────────────────────
  document.getElementById("btnBack").addEventListener("click", () => {
    const from = new URLSearchParams(window.location.search).get("from");
    window.location.href = from ? `/${from}` : "/circuits";
  });

  // ─── Modal Vincular DID ───────────────────────────────────────────────────────
  document.getElementById("btnAddDid").addEventListener("click", openModal);
  document.getElementById("btnModalCancel").addEventListener("click", closeModal);
  modalOverlay.addEventListener("click", closeModal);
  document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); });

  async function openModal() {
    modalMessage.classList.add("hidden");
    semDIDsMsg.classList.add("hidden");
    ssDID.setOptions([]);

    try {
      const res = await fetch("/api/did/free");
      const livres = await res.json();
      if (!Array.isArray(livres) || livres.length === 0) {
        semDIDsMsg.classList.remove("hidden");
      } else {
        ssDID.setOptions(livres.map(d => ({ value: String(d.id), label: formatNumber(d.number) })));
      }
    } catch {
      semDIDsMsg.textContent = "Erro ao carregar DIDs disponíveis.";
      semDIDsMsg.classList.remove("hidden");
    }

    modal.classList.remove("hidden");
    modalOverlay.classList.remove("hidden");
  }

  function closeModal() {
    modal.classList.add("hidden");
    modalOverlay.classList.add("hidden");
  }

  document.getElementById("btnModalSave").addEventListener("click", async () => {
    const didId = ssDID.getValue();
    if (!didId) { showModalMessage("Selecione um DID.", "error"); return; }

    try {
      const res = await fetch("/api/did/link", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ didId: Number(didId), circuitNumber: circuitId }),
      });
      if (res.ok) {
        closeModal();
        carregarDIDs();
        window.showToast?.("DID vinculado com sucesso!", "success");
      } else {
        const err = await res.text();
        showModalMessage(err || "Erro ao vincular DID.", "error");
      }
    } catch { showModalMessage("Erro ao comunicar com o servidor.", "error"); }
  });

  // ─── Init ─────────────────────────────────────────────────────────────────────
  carregarCircuito();
  carregarDIDs();
</script>
