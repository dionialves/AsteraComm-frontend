---
import Layout from "../../../layouts/Layout.astro";
const { id } = Astro.params;
---

<Layout>
    <div class="flex justify-between items-start page-header">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
                <a href="/circuits" class="hover:text-indigo-600 transition">Circuitos</a>
                <span>/</span>
                <span class="text-gray-600">DIDs</span>
            </div>
            <h1 class="page-title">DIDs — Circuito <span id="circuit-code">{id}</span></h1>
            <p class="page-subtitle">Numeração DID vinculada a este circuito</p>
        </div>
        <button id="btnAdd" class="bg-green-600 text-white rounded px-4 py-2 text-sm hover:bg-green-700">
            Vincular DID
        </button>
    </div>

    <div class="overflow-x-auto p-4 bg-white rounded-lg shadow">
        <table id="table-dids" class="table-fixed min-w-full border border-gray-200 rounded-lg shadow-sm text-sm">
            <thead class="bg-gray-100 text-gray-900">
                <tr class="font-semibold">
                    <th class="w-1/6 px-4 py-2 text-left">ID</th>
                    <th class="w-3/6 px-4 py-2 text-left">Número</th>
                    <th class="w-2/6 px-4 py-2 text-left">Ações</th>
                </tr>
            </thead>
            <tbody id="tbody-dids" class="divide-y divide-gray-200">
                <tr id="loading">
                    <td class="px-4 py-4 text-gray-500">Carregando...</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Modal Overlay -->
    <div id="modalOverlay" class="hidden fixed inset-0 bg-black/50 z-40"></div>

    <!-- Modal Vincular DID -->
    <div id="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
        <div class="bg-white rounded-lg shadow-lg w-full max-w-md">

            <div class="bg-gray-50 flex items-center justify-between px-6 py-4 border-b border-gray-200">
                <h2 class="text-lg font-semibold text-gray-800">Vincular DID ao Circuito</h2>
                <div class="flex items-center gap-2">
                    <button id="btnSave" class="bg-green-600 text-white rounded px-4 py-2 text-sm hover:bg-green-700 transition">
                        Vincular
                    </button>
                    <button id="btnCancel" class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300 text-sm text-gray-700 transition">
                        Cancelar
                    </button>
                </div>
            </div>

            <div class="px-6 py-4">
                <div id="formMessage" class="hidden mb-4 px-4 py-2 rounded text-sm"></div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">DID disponível <span class="text-red-500">*</span></label>
                    <select
                        id="selectDID"
                        class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring focus:border-blue-300"
                    >
                        <option value="">Selecione um DID...</option>
                    </select>
                    <p id="semDIDsMsg" class="hidden text-xs text-yellow-600 mt-1">Nenhum DID livre disponível. Cadastre DIDs em <a href="/dids" class="underline">DIDs</a>.</p>
                </div>
            </div>
        </div>
    </div>

<script type="module" defer>
    const circuitId = document.getElementById("circuit-code").textContent;
    const tbody = document.getElementById("tbody-dids");
    const loading = document.getElementById("loading");
    const modal = document.getElementById("modal");
    const modalOverlay = document.getElementById("modalOverlay");
    const selectDID = document.getElementById("selectDID");
    const formMessage = document.getElementById("formMessage");
    const semDIDsMsg = document.getElementById("semDIDsMsg");

    function formatNumber(digits) {
        if (!digits || digits.length !== 10) return digits;
        return `(${digits.substring(0, 2)}) ${digits.substring(2, 6)}-${digits.substring(6, 10)}`;
    }

    function showMessage(text, type) {
        formMessage.textContent = text;
        formMessage.classList.remove('hidden', 'bg-green-100', 'text-green-700', 'bg-red-100', 'text-red-700');
        formMessage.classList.add(type === 'success' ? 'bg-green-100' : 'bg-red-100');
        formMessage.classList.add(type === 'success' ? 'text-green-700' : 'text-red-700');
    }

    // === Carregar DIDs do circuito ===
    async function carregarDados() {
        try {
            const res = await fetch(`/api/did/dids?page=0&size=200`);
            const data = await res.json();
            const todos = data.content || [];

            loading.remove();
            tbody.innerHTML = "";

            const vinculados = todos.filter(d => d.circuitNumber === circuitId);

            if (vinculados.length === 0) {
                tbody.innerHTML = `<tr><td colspan="3" class="text-center py-4 text-gray-500">Nenhum DID vinculado a este circuito.</td></tr>`;
            } else {
                vinculados.forEach(item => {
                    const tr = document.createElement("tr");
                    tr.className = "odd:bg-gray-50 text-gray-700";
                    tr.dataset.id = item.id;
                    tr.innerHTML = `
                        <td class="px-4 py-2">${item.id}</td>
                        <td class="px-4 py-2 font-mono">${formatNumber(item.number)}</td>
                        <td class="px-4 py-2">
                            <button class="btn-unlink px-3 py-1 bg-red-600 text-white text-xs rounded hover:bg-red-700 transition">
                                Desvincular
                            </button>
                        </td>
                    `;
                    tr.querySelector('.btn-unlink').addEventListener('click', () => desvincular(item.id));
                    tbody.appendChild(tr);
                });
            }
        } catch {
            tbody.innerHTML = `<tr><td class="px-4 py-4 text-red-500">Erro ao carregar dados.</td></tr>`;
        }
    }

    // === Abrir modal com DIDs livres ===
    async function openModal() {
        formMessage.classList.add('hidden');
        selectDID.innerHTML = '<option value="">Selecione um DID...</option>';
        semDIDsMsg.classList.add('hidden');

        try {
            const res = await fetch(`/api/did/dids?page=0&size=200`);
            const data = await res.json();
            const livres = (data.content || []).filter(d => !d.circuitNumber);

            if (livres.length === 0) {
                semDIDsMsg.classList.remove('hidden');
            } else {
                livres.forEach(d => {
                    const opt = document.createElement('option');
                    opt.value = d.id;
                    opt.textContent = formatNumber(d.number);
                    selectDID.appendChild(opt);
                });
            }
        } catch {
            semDIDsMsg.textContent = 'Erro ao carregar DIDs disponíveis.';
            semDIDsMsg.classList.remove('hidden');
        }

        modal.classList.remove('hidden');
        modalOverlay.classList.remove('hidden');
    }

    function closeModal() {
        modal.classList.add('hidden');
        modalOverlay.classList.add('hidden');
    }

    // === Vincular ===
    document.getElementById("btnSave").addEventListener("click", async () => {
        const didId = selectDID.value;
        if (!didId) {
            showMessage('Selecione um DID.', 'error');
            return;
        }

        try {
            const res = await fetch('/api/did/link', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ didId: Number(didId), circuitNumber: circuitId }),
            });

            if (res.ok) {
                closeModal();
                carregarDados();
                window.showToast('DID vinculado com sucesso!', 'success');
            } else {
                const errorText = await res.text();
                showMessage(errorText || 'Erro ao vincular DID.', 'error');
            }
        } catch {
            showMessage('Erro ao comunicar com o servidor.', 'error');
        }
    });

    // === Desvincular ===
    async function desvincular(didId) {
        if (!confirm('Deseja desvincular este DID do circuito?')) return;

        try {
            const res = await fetch('/api/did/unlink', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ didId }),
            });

            if (res.ok) {
                carregarDados();
                window.showToast('DID desvinculado com sucesso!', 'success');
            } else {
                const errorText = await res.text();
                window.showToast(errorText || 'Erro ao desvincular DID.', 'error');
            }
        } catch {
            window.showToast('Erro ao comunicar com o servidor.', 'error');
        }
    }

    document.getElementById("btnAdd").addEventListener("click", openModal);
    document.getElementById("btnCancel").addEventListener("click", closeModal);
    modalOverlay.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
    });

    carregarDados();
</script>
</Layout>
