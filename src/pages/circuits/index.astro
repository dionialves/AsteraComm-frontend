---
import Layout from "../../layouts/Layout.astro";
---

<style is:global>
  main { background-color: #f9fafb; }

  .modal-overlay-did {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.15);
    z-index: 30;
    opacity: 0; pointer-events: none;
    transition: opacity 250ms ease;
  }
  .modal-overlay-did.active { opacity: 1; pointer-events: auto; }

  .modal-did {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    opacity: 0; pointer-events: none;
    width: 480px; height: 480px;
    background: #fff; border-radius: 12px;
    box-shadow: 0 12px 60px rgba(0,0,0,0.28);
    z-index: 35;
    display: flex; flex-direction: column;
    transition: transform 250ms cubic-bezier(0.4,0,0.2,1), opacity 250ms cubic-bezier(0.4,0,0.2,1);
  }
  .modal-did.open { transform: translate(-50%, -50%) scale(1); opacity: 1; pointer-events: auto; }

  .did-select-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: 6px; cursor: pointer;
    font-size: 13px; color: #374151;
    transition: background 0.12s;
  }
  .did-select-item:hover { background: #f3f4f6; }
  .did-select-item.selected { background: #eff6ff; color: #1d4ed8; font-weight: 500; }
  .did-select-num { flex: 1; }
  .did-select-id { font-size: 11px; color: #9ca3af; }
  .did-select-item.selected .did-select-id { color: #93c5fd; }
</style>


<Layout>
  <!-- ── Listing ─────────────────────────────────────────────────────────── -->
  <div class="bg-white rounded-lg shadow mb-6">
    <div class="flex items-center justify-between px-6 py-5">
      <div>
        <h1 class="page-title">Circuitos</h1>
        <p class="page-subtitle">Gerenciamento de ramais SIP e clientes ativos</p>
      </div>
      <button id="btnAdd" class="bg-green-600 text-white text-sm font-medium px-4 py-2 rounded-md hover:bg-green-700">+ Adicionar</button>
    </div>
    <hr class="border-gray-200" />
    <div class="listing-toolbar px-6 py-3">
      <div class="listing-search">
        <input id="input-search" type="text" placeholder="Pesquisar..." class="listing-search-input" />
        <button id="btn-search" class="listing-search-btn" title="Pesquisar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </div>
      <div class="listing-pagination">
        <button id="btn-prev" class="listing-page-btn">‹ Anterior</button>
        <span id="page-info" class="listing-page-info">Página 1 de 1</span>
        <button id="btn-next" class="listing-page-btn">Próxima ›</button>
      </div>
    </div>
    <div class="overflow-x-auto px-4 pb-4">
      <table id="table-circuits" class="table-fixed w-full border border-gray-200 rounded-lg shadow-sm text-sm bg-white">
        <thead class="bg-gray-100 text-gray-900">
          <tr class="font-semibold">
            <th data-field="id"           class="w-16 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">ID</th>
            <th data-field="active"       class="w-20 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">Status</th>
            <th data-field="number"       class="w-36 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">Código</th>
            <th data-field="customerName" class="w-80 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">Cliente</th>
            <th data-field="planName"     class="w-80 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">Plano</th>
            <th data-field="trunkName"    class="w-48 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">Tronco</th>
            <th data-field="online"       class="w-20 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">Online</th>
            <th data-field="ip"           class="w-32 px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">IP</th>
            <th data-field="rtt"          class="px-4 py-2 text-left font-semibold whitespace-nowrap cursor-pointer">RTT</th>
          </tr>
        </thead>
        <tbody id="tbody-circuits" class="divide-y divide-gray-200">
          <tr id="loading"><td>Carregando...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ── Overlay 1 ───────────────────────────────────────────────────────── -->
  <div id="modal-overlay-1" class="modal-overlay"></div>

  <!-- ── Modal principal ────────────────────────────────────────────────── -->
  <div id="modal-main" class="modal-main">
    <div class="modal-header">
      <div class="modal-header-top">
        <div class="modal-header-titles">
          <span id="modal-subtitle" class="modal-subtitle">Circuito</span>
          <span id="modal-title"    class="modal-title">—</span>
        </div>
        <button id="modal-btn-close" class="modal-btn-close" title="Fechar">✕</button>
      </div>
      <div class="modal-tabs">
        <button class="modal-tab active" data-tab="detalhes">Detalhes</button>
        <button class="modal-tab"        data-tab="dids">DIDs</button>
        <button class="modal-tab"        data-tab="historico">Histórico</button>
      </div>
    </div>
    <div id="modal-error" class="modal-error"></div>
    <div class="modal-body">
      <!-- Tab: Detalhes -->
      <div id="tab-detalhes" class="tab-panel active">
        <p class="section-title">Identificação</p>
        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">ID</label>
            <input id="field-id" type="text" class="form-input" disabled />
          </div>
          <div class="form-group">
            <label class="form-label">Código</label>
            <input id="field-number" type="text" class="form-input" disabled />
          </div>
        </div>
        <div class="toggle-group">
          <label class="toggle-switch">
            <input id="field-active" type="checkbox" />
            <span class="toggle-slider"></span>
          </label>
          <span id="toggle-active-label" class="toggle-label">Ativo</span>
        </div>
        <hr class="section-divider" />
        <p class="section-title">Autenticação</p>
        <div class="form-group" style="margin-bottom:12px">
          <label class="form-label">Senha</label>
          <div class="input-password-wrap">
            <input id="field-password" type="password" class="form-input" autocomplete="new-password" />
            <button id="btn-toggle-pw" class="btn-eye" type="button" title="Ver senha">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>
        <hr class="section-divider" />
        <p class="section-title">Configuração</p>
        <div class="form-grid-2" style="margin-bottom:12px">
          <div class="form-group">
            <label class="form-label">Tronco</label>
            <div id="cs-trunk"></div>
          </div>
          <div class="form-group">
            <label class="form-label">Plano</label>
            <div id="cs-plan"></div>
          </div>
        </div>
        <div class="form-group" style="max-width:50%">
          <label class="form-label">Cliente</label>
          <div id="cs-customer"></div>
        </div>
      </div>
      <!-- Tab: DIDs -->
      <div id="tab-dids" class="tab-panel">
        <div style="display:flex;justify-content:flex-end;margin-bottom:12px">
          <button id="btn-add-did" class="btn-modal-cancel" type="button">+ Adicionar</button>
        </div>
        <div class="did-grid-header">
          <span>ID</span><span>Número</span><span>Vinculado em</span><span></span>
        </div>
        <div id="did-list"></div>
      </div>
      <!-- Tab: Histórico -->
      <div id="tab-historico" class="tab-panel">
        <div id="history-list" class="history-list"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button id="btn-delete-circuit" class="btn-modal-delete" type="button">Deletar</button>
      <div class="modal-footer-right">
        <button id="btn-cancel-circuit" class="btn-modal-cancel" type="button">Cancelar</button>
        <button id="btn-save-circuit"   class="btn-modal-save"   type="button">Salvar</button>
      </div>
    </div>
  </div>

  <!-- ── Overlay DID ────────────────────────────────────────────────────── -->
  <div id="modal-overlay-did" class="modal-overlay-did"></div>

  <!-- ── Modal DID (seleção) ────────────────────────────────────────────── -->
  <div id="modal-did" class="modal-did">
    <div class="modal-header">
      <div class="modal-header-top">
        <div class="modal-header-titles">
          <span class="modal-subtitle">Circuito</span>
          <span class="modal-title" style="font-size:16px">Adicionar DID</span>
        </div>
        <button id="did-btn-close" class="modal-btn-close" title="Fechar">✕</button>
      </div>
    </div>
    <div class="modal-body" style="display:flex;flex-direction:column;gap:12px;overflow:hidden">
      <input id="did-search-input" type="text" class="form-input" placeholder="Pesquisar número..." />
      <div id="did-available-list" style="flex:1;overflow-y:auto"></div>
    </div>
    <div class="modal-footer">
      <div></div>
      <div class="modal-footer-right">
        <button id="did-btn-cancel"  class="btn-modal-cancel" type="button">Cancelar</button>
        <button id="did-btn-confirm" class="btn-modal-save"   type="button" disabled style="opacity:0.5;cursor:default">Adicionar</button>
      </div>
    </div>
  </div>

  <!-- ── Overlay 2 ───────────────────────────────────────────────────────── -->
  <div id="modal-overlay-2" class="modal-overlay-2"></div>

  <!-- ── Sub-modal ──────────────────────────────────────────────────────── -->
  <div id="modal-sub" class="modal-sub">
    <div class="sub-modal-header">
      <button id="sub-btn-back" class="btn-sub-back" title="Voltar">←</button>
      <div class="sub-modal-titles">
        <span id="sub-modal-subtitle" class="modal-subtitle">—</span>
        <span id="sub-modal-title"    class="modal-title" style="font-size:16px">—</span>
      </div>
      <button id="sub-btn-close" class="modal-btn-close" title="Fechar tudo">✕</button>
    </div>
    <div id="sub-modal-error" class="modal-error"></div>
    <div class="modal-body">
      <div id="sub-modal-content"></div>
    </div>
    <div class="modal-footer">
      <button id="sub-btn-delete" class="btn-modal-delete" type="button">Deletar</button>
      <div class="modal-footer-right">
        <button id="sub-btn-back2" class="btn-modal-cancel" type="button">Voltar</button>
        <button id="sub-btn-save"  class="btn-modal-save"   type="button">Salvar</button>
      </div>
    </div>
  </div>

<script type="module">
  // ── ModalSystem ──────────────────────────────────────────────────────────
  class ModalSystem {
    constructor(elements) {
      this.el = elements;
      this._subOpen = false;
      this._mainOpen = false;
      elements.overlay1.addEventListener("click", () => this.closeAll());
      elements.overlay2.addEventListener("click", () => this.closeSub());
      document.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") return;
        if (this._subOpen) this.closeSub();
        else if (this._mainOpen) this.closeAll();
      });
    }
    openMain(urlParam) {
      this.el.overlay1.classList.add("active");
      this.el.modalMain.classList.add("open");
      this._mainOpen = true;
      if (urlParam) {
        const url = new URL(window.location.href);
        url.searchParams.set("modal", urlParam);
        history.pushState({ modal: urlParam }, "", url.toString());
      }
    }
    openSub() {
      this.el.modalMain.classList.remove("open");
      this.el.modalMain.classList.add("behind");
      this.el.overlay2.classList.add("active");
      this.el.modalSub.classList.add("open");
      this._subOpen = true;
    }
    closeSub() {
      this.el.modalSub.classList.remove("open");
      this.el.overlay2.classList.remove("active");
      this.el.modalMain.classList.remove("behind");
      this.el.modalMain.classList.add("open");
      this._subOpen = false;
    }
    closeAll() {
      if (this._subOpen) {
        this.el.modalSub.classList.remove("open");
        this.el.overlay2.classList.remove("active");
        this.el.modalMain.classList.remove("behind");
        this._subOpen = false;
      }
      this.el.modalMain.classList.remove("open");
      this.el.overlay1.classList.remove("active");
      this._mainOpen = false;
      const url = new URL(window.location.href);
      url.searchParams.delete("modal");
      history.replaceState(null, "", url.toString());
    }
  }

  // ── SearchSelect (inline — sem imports) ──────────────────────────────────
  class SearchSelect {
    constructor(container, options, config = {}) {
      this._container  = container;
      this._options    = options;
      this._value      = "";
      this._label      = "";
      this._locked     = false;
      this._placeholder     = config.placeholder ?? "Selecione...";
      this._onChange        = config.onChange ?? null;
      this._linkClickHandler = null;
      this._boundClose = this._onOutsideClick.bind(this);
      this._render();
      this._renderList("");
    }

    getValue() { return this._value; }

    setValue(value) {
      const found = this._options.find(o => o.value === value);
      if (!found) return;
      this._value = found.value;
      this._label = found.label;
      this._setLocked(true);
      this._updateTriggerLabel();
      this._updateActions();
    }

    clear() {
      this._value = "";
      this._label = "";
      this._setLocked(false);
      this._updateTriggerLabel();
      this._updateActions();
    }

    setOptions(options) {
      this._options = options;
      this.clear();
      if (this._searchInput) this._searchInput.value = "";
      this._renderList("");
    }

    setLinkClickHandler(fn) { this._linkClickHandler = fn; }

    _render() {
      this._container.innerHTML = "";
      this._container.classList.add("flex", "items-center", "gap-1");

      this._inner = document.createElement("div");
      this._inner.className = "relative flex-1 min-w-0";

      this._trigger = document.createElement("button");
      this._trigger.type = "button";
      this._trigger.className = "w-full flex items-center justify-between px-3 py-2 border border-gray-300 rounded text-sm bg-white text-left focus:outline-none cursor-pointer";
      this._trigger.addEventListener("click", () => this._toggle());

      const labelSpan = document.createElement("span");
      labelSpan.dataset.label = "1";
      labelSpan.textContent = this._placeholder;
      labelSpan.className = "text-gray-400 truncate";

      this._arrow = document.createElement("span");
      this._arrow.innerHTML = `<svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>`;

      this._trigger.appendChild(labelSpan);
      this._trigger.appendChild(this._arrow);

      this._dropdown = document.createElement("div");
      this._dropdown.className = "hidden absolute left-0 right-0 top-full mt-1 z-50 bg-white border border-gray-300 rounded shadow-lg";

      this._searchInput = document.createElement("input");
      this._searchInput.type = "text";
      this._searchInput.placeholder = "Pesquisar...";
      this._searchInput.className = "w-full px-3 py-2 text-sm border-b border-gray-200 focus:outline-none";
      this._searchInput.addEventListener("input", () => this._renderList(this._searchInput.value));

      this._list = document.createElement("ul");
      this._list.className = "max-h-52 overflow-y-auto";

      this._emptyMsg = document.createElement("li");
      this._emptyMsg.className = "hidden px-3 py-2 text-sm text-gray-400 text-center";
      this._emptyMsg.textContent = "Nenhuma opção encontrada.";

      this._dropdown.appendChild(this._searchInput);
      this._dropdown.appendChild(this._list);
      this._dropdown.appendChild(this._emptyMsg);

      this._inner.appendChild(this._trigger);
      this._inner.appendChild(this._dropdown);

      this._btnClear = document.createElement("button");
      this._btnClear.type = "button";
      this._btnClear.className = "flex-shrink-0 p-1 text-gray-400 hover:text-red-500 transition";
      this._btnClear.style.display = "none";
      this._btnClear.title = "Limpar";
      this._btnClear.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>`;
      this._btnClear.addEventListener("click", () => this.clear());

      this._btnLink = document.createElement("button");
      this._btnLink.type = "button";
      this._btnLink.className = "flex-shrink-0 p-1 text-gray-400 hover:text-blue-600 transition";
      this._btnLink.style.display = "none";
      this._btnLink.title = "Ver detalhes";
      this._btnLink.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>`;
      this._btnLink.addEventListener("click", () => { if (this._linkClickHandler) this._linkClickHandler(); });

      this._container.appendChild(this._inner);
      this._container.appendChild(this._btnClear);
      this._container.appendChild(this._btnLink);
    }

    _renderList(query) {
      const q = query.toLowerCase();
      const filtered = this._options.filter(o => o.label.toLowerCase().includes(q)).slice(0, 10);
      this._list.innerHTML = "";
      this._emptyMsg.classList.add("hidden");
      if (!filtered.length) { this._emptyMsg.classList.remove("hidden"); return; }
      filtered.forEach(opt => {
        const li = document.createElement("li");
        li.textContent = opt.label;
        li.className = "px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 cursor-pointer";
        li.addEventListener("click", () => this._select(opt));
        this._list.appendChild(li);
      });
    }

    _toggle() {
      if (this._locked) return;
      this._dropdown.classList.contains("hidden") ? this._open() : this._close();
    }

    _open() {
      this._dropdown.classList.remove("hidden");
      this._searchInput.value = "";
      this._renderList("");
      this._searchInput.focus();
      document.addEventListener("mousedown", this._boundClose);
    }

    _close() {
      this._dropdown.classList.add("hidden");
      document.removeEventListener("mousedown", this._boundClose);
    }

    _select(opt) {
      this._value = opt.value;
      this._label = opt.label;
      this._setLocked(true);
      this._updateTriggerLabel();
      this._updateActions();
      this._close();
      if (this._onChange) this._onChange(opt.value, opt.label);
    }

    _setLocked(locked) {
      this._locked = locked;
      if (locked) {
        // Chip mode: visual unificado com bg cinza e botões com borda separadora
        this._container.classList.remove("gap-1");
        this._container.classList.add("cs-chip");
        this._inner.style.cssText = "display:flex;align-items:center;height:100%;flex:1;min-width:0;position:relative";
        this._trigger.className = "cs-chip-text pointer-events-none border-0 bg-transparent h-full text-left";
        this._arrow.style.display = "none";
        this._btnLink.className  = "cs-chip-link";
        this._btnClear.className = "cs-chip-clear";
      } else {
        // Search mode: trigger com borda e bg branco
        this._container.classList.add("gap-1");
        this._container.classList.remove("cs-chip");
        this._inner.style.cssText = "position:relative;flex:1;min-width:0";
        this._trigger.className = "w-full flex items-center justify-between px-3 py-2 border border-gray-300 rounded text-sm bg-white text-left focus:outline-none cursor-pointer";
        this._arrow.style.display = "";
        this._btnLink.className  = "flex-shrink-0 p-1 text-gray-400 hover:text-blue-600 transition";
        this._btnClear.className = "flex-shrink-0 p-1 text-gray-400 hover:text-red-500 transition";
      }
    }

    _updateTriggerLabel() {
      const span = this._trigger.querySelector("[data-label]");
      if (this._label) {
        span.textContent = this._label;
        span.className = "text-gray-700 truncate";
      } else {
        span.textContent = this._placeholder;
        span.className = "text-gray-400 truncate";
      }
    }

    _updateActions() {
      const has = this._value !== "";
      this._btnClear.style.display = has ? "" : "none";
      this._btnLink.style.display  = has ? "" : "none";
    }

    _onOutsideClick(e) {
      if (!this._container.contains(e.target)) this._close();
    }
  }

  // ── Elements ──────────────────────────────────────────────────────────────
  const tbody       = document.getElementById("tbody-circuits");
  const loading     = document.getElementById("loading");
  const table       = document.getElementById("table-circuits");
  const btnPrev     = document.getElementById("btn-prev");
  const btnNext     = document.getElementById("btn-next");
  const pageInfo    = document.getElementById("page-info");
  const searchInput = document.getElementById("input-search");

  let currentPage          = 0;
  let totalPages           = 0;
  let currentSortField     = "id";
  let currentSortDirection = "desc";

  // ── Modal system ──────────────────────────────────────────────────────────
  const ms = new ModalSystem({
    overlay1:  document.getElementById("modal-overlay-1"),
    modalMain: document.getElementById("modal-main"),
    overlay2:  document.getElementById("modal-overlay-2"),
    modalSub:  document.getElementById("modal-sub"),
  });

  // ── Chip selects ──────────────────────────────────────────────────────────
  const csTrunk    = new SearchSelect(document.getElementById("cs-trunk"),    [], { placeholder: "Selecionar tronco..." });
  const csPlan     = new SearchSelect(document.getElementById("cs-plan"),     [], { placeholder: "Selecionar plano..." });
  const csCustomer = new SearchSelect(document.getElementById("cs-customer"), [], { placeholder: "Selecionar cliente..." });

  // ── State ─────────────────────────────────────────────────────────────────
  let currentCircuitId   = null;
  let currentCircuitNumber = null;
  let deleteClickCount   = 0;
  let deleteTimer        = null;
  let subDeleteCount     = 0;
  let subDeleteTimer     = null;
  let subEntityType      = null; // "trunk" | "plan" | "customer"
  let subEntityId        = null;

  // ── Listing ───────────────────────────────────────────────────────────────
  document.getElementById("btnAdd").addEventListener("click", () => {
    window.location.href = "/circuits/new";
  });

  document.querySelectorAll("thead th[data-field]").forEach(th => {
    th.addEventListener("click", () => {
      const field = th.getAttribute("data-field");
      if (currentSortField === field) {
        currentSortDirection = currentSortDirection === "asc" ? "desc" : "asc";
      } else {
        currentSortField     = field;
        currentSortDirection = "asc";
      }
      carregarDados(0);
    });
  });

  searchInput.addEventListener("keydown", e => { if (e.key === "Enter") carregarDados(0); });
  document.getElementById("btn-search").addEventListener("click", () => carregarDados(0));

  function formatDate(d) {
    if (!d) return "—";
    return new Date(d).toLocaleDateString("pt-BR", { day:"2-digit", month:"2-digit", year:"numeric", hour:"2-digit", minute:"2-digit" });
  }

  function carregarDados(pagina) {
    loading.style.display = "block";
    table.style.visibility = "visible";
    const search = encodeURIComponent(searchInput.value.trim());
    const url = `/api/circuit/circuits?page=${pagina}&size=20&sort=${currentSortField},${currentSortDirection}&search=${search}`;

    fetch(url)
      .then(r => { if (!r.ok) throw new Error(); return r.json(); })
      .then(data => {
        loading.style.display = "none";
        table.style.display   = "table";
        currentPage = pagina;
        totalPages  = data.totalPages;
        tbody.innerHTML = "";

        if (data.content.length === 0) {
          tbody.innerHTML = `<tr><td colspan="9" class="text-center py-4 text-gray-500">Nenhum circuito encontrado.</td></tr>`;
        } else {
          data.content.forEach(item => {
            const tr = document.createElement("tr");
            tr.className = "odd:bg-gray-50 text-gray-700 hover:bg-gray-100 transition-colors cursor-pointer";
            tr.dataset.id = item.id;
            tr.innerHTML = `
              <td class="px-4 py-2 text-gray-500">${item.id}</td>
              <td class="px-4 py-2 font-semibold ${item.active ? 'text-green-600' : 'text-red-600'}">${item.active ? 'Ativo' : 'Inativo'}</td>
              <td class="px-4 py-2">${item.number}</td>
              <td class="px-4 py-2 text-gray-600">${item.customerName || '—'}</td>
              <td class="px-4 py-2 text-gray-600">${item.planName || '—'}</td>
              <td class="px-4 py-2 text-gray-600">${item.trunkName || '—'}</td>
              <td class="px-4 py-2 font-semibold ${item.online ? 'text-green-600' : 'text-red-600'}">${item.online ? 'OK' : 'Offline'}</td>
              <td class="px-4 py-2 text-gray-600">${item.ip || '—'}</td>
              <td class="px-4 py-2 text-gray-600">${item.rtt || '—'}</td>
            `;
            tr.addEventListener("click", () => openCircuitModal(item.id, item.number));
            tbody.appendChild(tr);
          });
        }
        pageInfo.textContent = `Página ${currentPage + 1} de ${totalPages === 0 ? 1 : totalPages}`;
      })
      .catch(() => { loading.textContent = "Erro ao carregar dados."; });
  }

  btnPrev.addEventListener("click", () => { if (currentPage > 0) carregarDados(currentPage - 1); });
  btnNext.addEventListener("click", () => { if (currentPage < totalPages - 1) carregarDados(currentPage + 1); });

  // ── Load chip options ─────────────────────────────────────────────────────
  let trunksData = [];

  async function loadChipOptions() {
    const [trunks, plans, customers] = await Promise.all([
      fetch("/api/trunk/trunks?page=0&size=200").then(r => r.ok ? r.json() : { content: [] }),
      fetch("/api/plan/plans?page=0&size=200").then(r => r.ok ? r.json() : { content: [] }),
      fetch("/api/customer/customers?page=0&size=200").then(r => r.ok ? r.json() : { content: [] }),
    ]);
    trunksData = trunks.content || [];
    // Trunk: value = name (entidade Circuit armazena trunkName como string)
    csTrunk.setOptions(trunksData.map(t => ({ value: t.name, label: t.name })));
    csPlan.setOptions((plans.content || []).map(p => ({ value: String(p.id), label: p.name })));
    csCustomer.setOptions((customers.content || []).map(c => ({ value: String(c.id), label: c.name })));
  }

  // ── Open circuit modal ────────────────────────────────────────────────────
  async function openCircuitModal(id, number) {
    currentCircuitId     = id;
    currentCircuitNumber = number;
    hideModalError();
    resetDeleteBtn();

    await loadChipOptions();

    const r = await fetch(`/api/circuit/${number}`);
    if (!r.ok) return;
    const c = await r.json();

    // Populate header
    document.getElementById("modal-title").textContent    = c.number;
    document.getElementById("modal-subtitle").textContent = "Circuito";

    // Populate fields
    document.getElementById("field-id").value       = c.id;
    document.getElementById("field-number").value   = c.number;
    document.getElementById("field-active").checked = c.active;
    document.getElementById("toggle-active-label").textContent = c.active ? "Ativo" : "Inativo";
    document.getElementById("field-password").value = c.password || "";

    // Chips
    // Trunk: armazenado como string trunkName na entidade, sem FK
    if (c.trunkName) csTrunk.setValue(c.trunkName); else csTrunk.clear();
    // Plan: objeto aninhado EAGER
    if (c.plan?.id)  csPlan.setValue(String(c.plan.id));  else csPlan.clear();
    // Customer: objeto aninhado LAZY (pode ser null)
    if (c.customer?.id) csCustomer.setValue(String(c.customer.id)); else csCustomer.clear();

    // Chip link handlers — para trunk precisa buscar o ID pelo nome na lista carregada
    const trunkObj = trunksData.find(t => t.name === c.trunkName);
    csTrunk.setLinkClickHandler(() => openSubModal("trunk", trunkObj?.id));
    csPlan.setLinkClickHandler(() => openSubModal("plan", c.plan?.id));
    csCustomer.setLinkClickHandler(() => openSubModal("customer", c.customer?.id));

    // Activate Detalhes tab
    activateTab("detalhes");

    ms.openMain(String(c.number));
  }

  // ── Tabs ──────────────────────────────────────────────────────────────────
  document.querySelectorAll(".modal-tab").forEach(btn => {
    btn.addEventListener("click", () => {
      const tab = btn.getAttribute("data-tab");
      activateTab(tab);
      if (tab === "dids")      loadDids();
      if (tab === "historico") loadHistory();
    });
  });

  function activateTab(name) {
    document.querySelectorAll(".modal-tab").forEach(b => b.classList.toggle("active", b.getAttribute("data-tab") === name));
    document.querySelectorAll(".tab-panel").forEach(p => p.classList.toggle("active", p.id === `tab-${name}`));
  }

  // ── Toggle active label ───────────────────────────────────────────────────
  document.getElementById("field-active").addEventListener("change", function() {
    document.getElementById("toggle-active-label").textContent = this.checked ? "Ativo" : "Inativo";
  });

  // ── Password visibility ───────────────────────────────────────────────────
  document.getElementById("btn-toggle-pw").addEventListener("click", () => {
    const input = document.getElementById("field-password");
    input.type  = input.type === "password" ? "text" : "password";
  });

  // ── DIDs tab ──────────────────────────────────────────────────────────────
  async function loadDids() {
    const list = document.getElementById("did-list");
    list.innerHTML = `<p class="did-empty">Carregando...</p>`;
    const r = await fetch(`/api/did/by-circuit/${currentCircuitNumber}`);
    if (!r.ok) { list.innerHTML = `<p class="did-empty">Erro ao carregar DIDs.</p>`; return; }
    const dids = await r.json();
    if (!dids.length) { list.innerHTML = `<p class="did-empty">Nenhum DID vinculado.</p>`; return; }
    list.innerHTML = dids.map(d => `
      <div class="did-grid-row">
        <span>${d.id}</span>
        <span>${d.number}</span>
        <span>${d.linkedAt ? new Date(d.linkedAt).toLocaleDateString("pt-BR") : "—"}</span>
        <button class="btn-did-unlink" data-did-id="${d.id}" data-did-number="${d.number}" title="Desvincular">✕</button>
      </div>
    `).join("");
    list.querySelectorAll(".btn-did-unlink").forEach(btn => {
      btn.addEventListener("click", async () => {
        const didId  = btn.getAttribute("data-did-id");
        const number = btn.getAttribute("data-did-number");
        if (!confirm(`Deseja desvincular o DID ${number} deste circuito?`)) return;
        const r2 = await fetch("/api/did/unlink", { method: "POST", headers: { "Content-Type":"application/json" }, body: JSON.stringify({ didId: Number(didId) }) });
        if (r2.ok) loadDids();
      });
    });
  }

  document.getElementById("btn-add-did").addEventListener("click", () => openDidModal());

  // ── DID search modal ──────────────────────────────────────────────────────
  let didSearchData  = [];
  let selectedDidId  = null;

  async function openDidModal() {
    selectedDidId = null;
    document.getElementById("did-search-input").value = "";
    document.getElementById("did-available-list").innerHTML =
      `<p style="color:#9ca3af;font-size:13px;padding:16px 0;text-align:center">Carregando...</p>`;
    setDidConfirmState(false);

    const r = await fetch("/api/did/free");
    if (!r.ok) {
      document.getElementById("did-available-list").innerHTML =
        `<p style="color:#ef4444;font-size:13px;padding:16px 0;text-align:center">Erro ao carregar DIDs.</p>`;
    } else {
      const data = await r.json();
      didSearchData = Array.isArray(data) ? data : (data.content || []);
      renderDidSearchList("");
    }

    document.getElementById("modal-overlay-did").classList.add("active");
    document.getElementById("modal-did").classList.add("open");
  }

  function closeDidModal() {
    document.getElementById("modal-did").classList.remove("open");
    document.getElementById("modal-overlay-did").classList.remove("active");
  }

  function renderDidSearchList(query) {
    const q = query.toLowerCase();
    const filtered = didSearchData
      .filter(d => String(d.number || d.id).toLowerCase().includes(q))
      .slice(0, 50);
    const list = document.getElementById("did-available-list");
    if (!filtered.length) {
      list.innerHTML = `<p style="color:#9ca3af;font-size:13px;padding:16px 0;text-align:center">Nenhum DID encontrado.</p>`;
      return;
    }
    list.innerHTML = "";
    filtered.forEach(d => {
      const item = document.createElement("div");
      item.className = "did-select-item" + (selectedDidId === d.id ? " selected" : "");
      item.dataset.id = d.id;
      item.innerHTML = `<span class="did-select-num">${d.number}</span><span class="did-select-id">ID ${d.id}</span>`;
      item.addEventListener("click", () => {
        selectedDidId = d.id;
        list.querySelectorAll(".did-select-item").forEach(el => el.classList.remove("selected"));
        item.classList.add("selected");
        setDidConfirmState(true);
      });
      list.appendChild(item);
    });
  }

  function setDidConfirmState(enabled) {
    const btn = document.getElementById("did-btn-confirm");
    btn.disabled = !enabled;
    btn.style.opacity = enabled ? "" : "0.5";
    btn.style.cursor  = enabled ? "" : "default";
  }

  document.getElementById("did-search-input").addEventListener("input", e => {
    renderDidSearchList(e.target.value);
  });

  document.getElementById("did-btn-close").addEventListener("click",  closeDidModal);
  document.getElementById("did-btn-cancel").addEventListener("click", closeDidModal);
  document.getElementById("modal-overlay-did").addEventListener("click", closeDidModal);

  document.getElementById("did-btn-confirm").addEventListener("click", async () => {
    if (!selectedDidId) return;
    const r = await fetch("/api/did/link", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ didId: selectedDidId, circuitNumber: currentCircuitNumber }),
    });
    if (r.ok) {
      closeDidModal();
      loadDids();
    } else {
      const err = await r.json().catch(() => ({}));
      alert(err.message || "Erro ao vincular DID.");
    }
  });

  // ── History tab ───────────────────────────────────────────────────────────
  async function loadHistory() {
    const list = document.getElementById("history-list");
    list.innerHTML = `<p class="history-empty">Carregando...</p>`;
    // History endpoint not implemented yet — show empty state
    list.innerHTML = `<p class="history-empty">Nenhum registro.</p>`;
  }

  // ── Save circuit ──────────────────────────────────────────────────────────
  document.getElementById("btn-save-circuit").addEventListener("click", async () => {
    hideModalError();
    const body = {
      active:     document.getElementById("field-active").checked,
      password:   document.getElementById("field-password").value || undefined,
      trunkName:  csTrunk.getValue()    || null,
      planId:     csPlan.getValue()     ? Number(csPlan.getValue())     : null,
      customerId: csCustomer.getValue() ? Number(csCustomer.getValue()) : null,
    };
    const r = await fetch(`/api/circuit/${currentCircuitNumber}`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    if (r.ok) {
      ms.closeAll();
      carregarDados(currentPage);
    } else {
      const err = await r.json().catch(() => ({}));
      showModalError(err.message || "Erro ao salvar circuito.");
    }
  });

  // ── Delete circuit ────────────────────────────────────────────────────────
  document.getElementById("btn-delete-circuit").addEventListener("click", async () => {
    const btn = document.getElementById("btn-delete-circuit");
    if (deleteClickCount === 0) {
      deleteClickCount = 1;
      btn.textContent  = "Confirmar exclusão";
      btn.classList.add("confirm");
      deleteTimer = setTimeout(resetDeleteBtn, 3000);
    } else {
      clearTimeout(deleteTimer);
      const r = await fetch(`/api/circuit/${currentCircuitNumber}`, { method: "DELETE" });
      if (r.ok || r.status === 204) {
        ms.closeAll();
        carregarDados(currentPage);
      } else {
        const err = await r.json().catch(() => ({}));
        showModalError(err.message || "Erro ao deletar circuito.");
        resetDeleteBtn();
      }
    }
  });

  document.getElementById("btn-cancel-circuit").addEventListener("click", () => ms.closeAll());
  document.getElementById("modal-btn-close").addEventListener("click",    () => ms.closeAll());

  function resetDeleteBtn() {
    deleteClickCount = 0;
    const btn = document.getElementById("btn-delete-circuit");
    btn.textContent = "Deletar";
    btn.classList.remove("confirm");
  }

  // ── Sub-modal ─────────────────────────────────────────────────────────────
  async function openSubModal(type, id) {
    if (!id) return;
    subEntityType = type;
    subEntityId   = id;
    hideSubModalError();
    resetSubDeleteBtn();

    const typeLabel = { trunk: "Tronco", plan: "Plano", customer: "Cliente" };
    document.getElementById("sub-modal-subtitle").textContent = typeLabel[type] || type;

    const r = await fetch(`/api/${type}/${id}`);
    if (!r.ok) return;
    const data = await r.json();

    document.getElementById("sub-modal-title").textContent = data.name || data.number || String(id);
    document.getElementById("sub-modal-content").innerHTML = buildSubModalContent(type, data);
    wireSubModalContent(type, data);
    ms.openSub();
  }

  function wireSubModalContent(type, data) {
    if (type === "customer") {
      // Toggle label
      const chk = document.getElementById("sub-field-enabled");
      const lbl = document.getElementById("sub-toggle-enabled-label");
      if (chk && lbl) chk.addEventListener("change", () => { lbl.textContent = chk.checked ? "Ativo" : "Inativo"; });

      // Tabs
      const subSaveBtn   = document.getElementById("sub-btn-save");
      const subDeleteBtn = document.getElementById("sub-btn-delete");
      document.querySelectorAll("[data-subtab]").forEach(btn => {
        btn.addEventListener("click", () => {
          const tab = btn.getAttribute("data-subtab");
          document.querySelectorAll("[data-subtab]").forEach(b => b.classList.toggle("active", b === btn));
          document.querySelectorAll("[id^='sub-tab-']").forEach(p => p.classList.toggle("active", p.id === `sub-tab-${tab}`));
          const isDetalhes = tab === "detalhes";
          if (subSaveBtn)   subSaveBtn.style.display   = isDetalhes ? "" : "none";
          if (subDeleteBtn) subDeleteBtn.style.display = isDetalhes ? "" : "none";
          if (tab === "circuitos") loadSubCustomerCircuits(data.id);
        });
      });
    }
  }

  async function loadSubCustomerCircuits(customerId) {
    const list = document.getElementById("sub-circuits-list");
    if (!list) return;
    list.innerHTML = `<p style="color:#9ca3af;font-size:13px;padding:16px 0;text-align:center">Carregando...</p>`;
    const r = await fetch(`/api/customer/${customerId}/circuits`);
    if (!r.ok) { list.innerHTML = `<p style="color:#9ca3af;font-size:13px;padding:16px 0;text-align:center">Erro ao carregar.</p>`; return; }
    const circuits = await r.json();
    if (!circuits.length) { list.innerHTML = `<p style="color:#9ca3af;font-size:13px;padding:16px 0;text-align:center">Nenhum circuito vinculado.</p>`; return; }
    list.innerHTML = `
      <div style="display:grid;grid-template-columns:50px 1fr 80px;gap:8px;font-size:13px;font-weight:600;color:#555;padding:4px 0 8px;border-bottom:1px solid #e5e7eb">
        <span>ID</span><span>Código</span><span>Status</span>
      </div>
      ${circuits.map(c => `
        <div style="display:grid;grid-template-columns:50px 1fr 80px;gap:8px;font-size:13px;padding:6px 0;border-bottom:1px solid #f3f4f6;color:#374151">
          <span>${c.id}</span><span>${c.number}</span>
          <span style="font-weight:600;color:${c.active ? '#16a34a' : '#dc2626'}">${c.active ? 'Ativo' : 'Inativo'}</span>
        </div>
      `).join("")}
    `;
  }

  function buildSubModalContent(type, d) {
    if (type === "trunk") return `
      <div class="form-grid-2">
        <div class="form-group"><label class="form-label">ID</label><input type="text" class="form-input" disabled value="${d.id || ''}"/></div>
        <div class="form-group"><label class="form-label">Nome</label><input id="sub-field-name" type="text" class="form-input" value="${d.name || ''}"/></div>
      </div>
      <div class="form-grid-2">
        <div class="form-group"><label class="form-label">Host</label><input id="sub-field-host" type="text" class="form-input" value="${d.host || ''}"/></div>
        <div class="form-group"><label class="form-label">Porta</label><input id="sub-field-port" type="text" class="form-input" value="${d.port || ''}"/></div>
      </div>
      <div class="form-group"><label class="form-label">Transporte</label><input id="sub-field-transport" type="text" class="form-input" value="${d.transport || ''}"/></div>
    `;
    if (type === "plan") return `
      <div class="form-grid-2">
        <div class="form-group"><label class="form-label">ID</label><input type="text" class="form-input" disabled value="${d.id || ''}"/></div>
        <div class="form-group"><label class="form-label">Nome</label><input id="sub-field-name" type="text" class="form-input" value="${d.name || ''}"/></div>
      </div>
      <div class="form-group"><label class="form-label">Descrição</label><input id="sub-field-description" type="text" class="form-input" value="${d.description || ''}"/></div>
    `;
    if (type === "customer") return `
      <div class="modal-tabs" style="margin: -20px -20px 0; padding: 0 20px">
        <button class="modal-tab active" data-subtab="detalhes">Detalhes</button>
        <button class="modal-tab" data-subtab="circuitos">Circuitos</button>
        <button class="modal-tab" data-subtab="historico">Histórico</button>
      </div>
      <div id="sub-tab-detalhes" class="tab-panel active" style="padding-top:20px">
        <p class="section-title">Identificação</p>
        <div class="form-grid-2">
          <div class="form-group"><label class="form-label">ID</label><input type="text" class="form-input" disabled value="${d.id || ''}"/></div>
          <div class="form-group"><label class="form-label">Nome</label><input id="sub-field-name" type="text" class="form-input" value="${d.name || ''}"/></div>
        </div>
        <div class="toggle-group">
          <label class="toggle-switch">
            <input id="sub-field-enabled" type="checkbox" ${d.enabled ? 'checked' : ''}/>
            <span class="toggle-slider"></span>
          </label>
          <span id="sub-toggle-enabled-label" class="toggle-label">${d.enabled ? 'Ativo' : 'Inativo'}</span>
        </div>
      </div>
      <div id="sub-tab-circuitos" class="tab-panel">
        <div id="sub-circuits-list"></div>
      </div>
      <div id="sub-tab-historico" class="tab-panel">
        <p class="history-empty">Nenhum registro.</p>
      </div>
    `;
    return "";
  }

  function collectSubModalBody() {
    const get = id => document.getElementById(id)?.value || "";
    if (subEntityType === "trunk") return {
      name:      get("sub-field-name"),
      host:      get("sub-field-host"),
      port:      get("sub-field-port") ? Number(get("sub-field-port")) : undefined,
      transport: get("sub-field-transport"),
    };
    if (subEntityType === "plan") return {
      name:        get("sub-field-name"),
      description: get("sub-field-description"),
    };
    if (subEntityType === "customer") return {
      name:    get("sub-field-name"),
      enabled: document.getElementById("sub-field-enabled")?.checked ?? true,
    };
    return {};
  }

  document.getElementById("sub-btn-save").addEventListener("click", async () => {
    hideSubModalError();
    const r = await fetch(`/api/${subEntityType}/${subEntityId}`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(collectSubModalBody()),
    });
    if (r.ok) {
      ms.closeSub();
      // Refresh chip label after sub-modal save
      const data = await r.json().catch(() => ({}));
      if (subEntityType === "trunk" && data.name) {
        trunksData = trunksData.map(t => t.id === subEntityId ? { ...t, name: data.name } : t);
        csTrunk.setOptions(trunksData.map(t => ({ value: t.name, label: t.name })));
        csTrunk.setValue(data.name);
      }
      if (subEntityType === "plan"     && data.name) csPlan.setValue(String(subEntityId));
      if (subEntityType === "customer" && data.name) csCustomer.setValue(String(subEntityId));
    } else {
      const err = await r.json().catch(() => ({}));
      showSubModalError(err.message || "Erro ao salvar.");
    }
  });

  document.getElementById("sub-btn-delete").addEventListener("click", async () => {
    const btn = document.getElementById("sub-btn-delete");
    if (subDeleteCount === 0) {
      subDeleteCount = 1;
      btn.textContent = "Confirmar exclusão";
      btn.classList.add("confirm");
      subDeleteTimer = setTimeout(resetSubDeleteBtn, 3000);
    } else {
      clearTimeout(subDeleteTimer);
      const r = await fetch(`/api/${subEntityType}/${subEntityId}`, { method: "DELETE" });
      if (r.ok || r.status === 204) {
        // Clear the chip that referenced this entity
        if (subEntityType === "trunk")    csTrunk.clear();
        if (subEntityType === "plan")     csPlan.clear();
        if (subEntityType === "customer") csCustomer.clear();
        ms.closeAll();
        carregarDados(currentPage);
      } else {
        const err = await r.json().catch(() => ({}));
        showSubModalError(err.message || "Erro ao deletar.");
        resetSubDeleteBtn();
      }
    }
  });

  document.getElementById("sub-btn-back").addEventListener("click",  () => ms.closeSub());
  document.getElementById("sub-btn-back2").addEventListener("click", () => ms.closeSub());
  document.getElementById("sub-btn-close").addEventListener("click", () => ms.closeAll());

  function resetSubDeleteBtn() {
    subDeleteCount = 0;
    const btn = document.getElementById("sub-btn-delete");
    btn.textContent = "Deletar";
    btn.classList.remove("confirm");
  }

  // ── Error helpers ─────────────────────────────────────────────────────────
  function showModalError(msg) {
    const el = document.getElementById("modal-error");
    el.textContent = msg;
    el.style.display = "block";
  }
  function hideModalError() {
    document.getElementById("modal-error").style.display = "none";
  }
  function showSubModalError(msg) {
    const el = document.getElementById("sub-modal-error");
    el.textContent = msg;
    el.style.display = "block";
  }
  function hideSubModalError() {
    document.getElementById("sub-modal-error").style.display = "none";
  }

  // ── Deep link on load ─────────────────────────────────────────────────────
  const urlParam = new URLSearchParams(window.location.search).get("modal");
  if (urlParam) {
    // Wait for data to load then open
    carregarDados(0);
    // Try to open after listing loads (simple approach: wait a tick)
    setTimeout(async () => {
      const tr = tbody.querySelector(`tr[data-id]`);
      // Find the row with matching number
      const rows = Array.from(tbody.querySelectorAll("tr[data-id]"));
      const row  = rows.find(r => r.children[2]?.textContent?.trim() === urlParam);
      if (row) openCircuitModal(Number(row.dataset.id), urlParam);
    }, 800);
  } else {
    carregarDados(0);
  }
</script>
</Layout>
