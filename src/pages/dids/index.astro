---
import Layout from "../../layouts/Layout.astro";
---

<style is:global>
  .did-row {
    display: grid;
    grid-template-columns: 48px minmax(0,1fr) 80px minmax(0,1fr);
    gap: 8px;
    padding: 11px 16px;
    align-items: center;
    cursor: pointer;
    background: #ffffff;
    border-bottom: 1px solid #f0f0f0;
    transition: background 0.1s;
  }
  .did-row:last-child { border-bottom: none; }
  .did-row:hover { background: #fafafa; }
  .did-row.row-selected { background: #E6F1FB !important; border-left: 2px solid #378ADD; }
</style>

<Layout>
  <!-- ── Header ────────────────────────────────────────────────────────────── -->
  <div class="flex items-start justify-between mb-5">
    <div>
      <h1 class="text-[22px] font-medium text-[#1a1a1a]">DIDs</h1>
      <p class="text-[13px] text-[#888] mt-0.5">Numeração DID disponível e vínculos com circuitos</p>
    </div>
    <button id="btnAdd" class="flex items-center gap-1.5 bg-[#1D9E75] text-white text-[13px] font-medium px-3 py-[9px] rounded-md hover:opacity-90 transition-opacity">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Novo DID
    </button>
  </div>

  <!-- ── Toolbar ───────────────────────────────────────────────────────────── -->
  <div class="flex items-center justify-between mb-3 gap-3 flex-wrap">
    <div class="flex items-center gap-3">
      <div class="relative w-[280px]">
        <svg class="absolute left-[10px] top-1/2 -translate-y-1/2 pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input id="input-search" type="text" placeholder="Buscar por número..."
          class="w-full pl-[34px] pr-3 py-[9px] text-[13px] border border-[#e0e0e0] rounded-md outline-none bg-white text-[#1a1a1a] placeholder-[#aaa] focus:border-[#1D9E75] transition-colors" />
      </div>
      <div class="flex border border-[#e0e0e0] rounded-md overflow-hidden text-[13px]">
        <button data-filter="all"    class="filter-btn px-3 py-[7px] bg-white text-[#1a1a1a] font-medium border-r border-[#e0e0e0]">Todos</button>
        <button data-filter="IN_USE" class="filter-btn px-3 py-[7px] text-[#888] border-r border-[#e0e0e0]">Em uso</button>
        <button data-filter="FREE"   class="filter-btn px-3 py-[7px] text-[#888]">Livres</button>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button id="btn-prev" class="w-7 h-7 flex items-center justify-center rounded border border-[#e0e0e0] text-[#888] hover:border-[#ccc] disabled:opacity-40 disabled:cursor-not-allowed transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <span id="page-info" class="text-[12px] text-[#888] whitespace-nowrap">Página 1 de 1</span>
      <button id="btn-next" class="w-7 h-7 flex items-center justify-center rounded border border-[#e0e0e0] text-[#888] hover:border-[#ccc] disabled:opacity-40 disabled:cursor-not-allowed transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>

  <!-- ── Table ─────────────────────────────────────────────────────────────── -->
  <div class="rounded-xl border border-[#e0e0e0] overflow-hidden">
    <div class="did-row bg-[#f5f5f5] border-b border-[#e0e0e0]" style="cursor:default">
      <span data-field="id"     class="sort-col text-[11px] font-medium text-[#888] uppercase tracking-wide cursor-pointer select-none flex items-center gap-1">ID</span>
      <span data-field="number" class="sort-col text-[11px] font-medium text-[#888] uppercase tracking-wide cursor-pointer select-none flex items-center gap-1">Número</span>
      <span                      class="text-[11px] font-medium text-[#888] uppercase tracking-wide">Status</span>
      <span                      class="text-[11px] font-medium text-[#888] uppercase tracking-wide">Circuito</span>
    </div>
    <div id="tbody-dids"></div>
  </div>

  <!-- ── Modal overlay ─────────────────────────────────────────────────────── -->
  <div id="modal-overlay" class="modal-overlay"></div>

  <!-- ── Modal DID ─────────────────────────────────────────────────────────── -->
  <div id="modal-main" class="modal-main">
    <div class="modal-header">
      <div class="modal-header-top">
        <div class="modal-header-titles">
          <span id="modal-subtitle" class="modal-subtitle">DID</span>
          <span id="modal-title"    class="modal-title">—</span>
        </div>
        <button id="modal-btn-close" class="modal-btn-close" title="Fechar">✕</button>
      </div>
    </div>
    <div id="modal-error" class="modal-error"></div>
    <div class="modal-body">
      <p class="section-title">Número</p>
      <div class="form-group">
        <label class="form-label">Número do DID</label>
        <input id="field-number" type="text" maxlength="15" class="form-input" placeholder="(XX) XXXX-XXXX" />
        <p style="font-size:11px;color:#aaa;margin-top:4px">Formato: (XX) XXXX-XXXX — apenas dígitos são armazenados</p>
      </div>
    </div>
    <div class="modal-footer">
      <button id="btn-delete-did" class="btn-modal-delete" type="button">Deletar</button>
      <div class="modal-footer-right">
        <button id="btn-cancel-did" class="btn-modal-cancel" type="button">Cancelar</button>
        <button id="btn-save-did"   class="btn-modal-save"   type="button">Salvar</button>
      </div>
    </div>
  </div>

<script type="module">
  // ── State ─────────────────────────────────────────────────────────────────
  const tbody       = document.getElementById("tbody-dids");
  const btnPrev     = document.getElementById("btn-prev");
  const btnNext     = document.getElementById("btn-next");
  const pageInfo    = document.getElementById("page-info");
  const searchInput = document.getElementById("input-search");

  let currentPage          = 0;
  let totalPages           = 0;
  let currentSortField     = "id";
  let currentSortDirection = "desc";
  let currentFilter        = "all";
  let currentDIDId         = null;
  let deleteClickCount     = 0;
  let deleteTimer          = null;
  let debounceTimer        = null;

  // ── Modal helpers ─────────────────────────────────────────────────────────
  const overlay  = document.getElementById("modal-overlay");
  const modalEl  = document.getElementById("modal-main");

  function openModal() {
    overlay.classList.add("active");
    modalEl.classList.add("open");
  }

  function closeModal() {
    deselectRows();
    overlay.classList.remove("active");
    modalEl.classList.remove("open");
    const url = new URL(window.location.href);
    url.searchParams.delete("modal");
    history.replaceState(null, "", url.toString());
  }

  overlay.addEventListener("click", closeModal);
  document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); });
  document.getElementById("modal-btn-close").addEventListener("click", closeModal);
  document.getElementById("btn-cancel-did").addEventListener("click", closeModal);

  function deselectRows() {
    document.querySelectorAll(".did-row.row-selected").forEach(r => r.classList.remove("row-selected"));
  }

  function showModalError(msg) {
    const el = document.getElementById("modal-error");
    el.textContent = msg; el.style.display = "block";
  }
  function hideModalError() {
    document.getElementById("modal-error").style.display = "none";
  }

  // ── Number mask ───────────────────────────────────────────────────────────
  function applyMask(input) {
    let d = input.value.replace(/\D/g, "").substring(0, 10);
    let f = "";
    if (d.length > 0) f = "(" + d.substring(0, 2);
    if (d.length >= 2) f += ") ";
    if (d.length > 2)  f += d.substring(2, 6);
    if (d.length > 6)  f += "-" + d.substring(6, 10);
    input.value = f;
  }

  function formatNumber(digits) {
    if (!digits || digits.length !== 10) return digits;
    return `(${digits.substring(0,2)}) ${digits.substring(2,6)}-${digits.substring(6,10)}`;
  }

  document.getElementById("field-number").addEventListener("input", function() { applyMask(this); });

  // ── New DID ───────────────────────────────────────────────────────────────
  document.getElementById("btnAdd").addEventListener("click", () => {
    currentDIDId = null;
    hideModalError();
    resetDeleteBtn();
    document.getElementById("modal-title").textContent             = "Novo DID";
    document.getElementById("modal-subtitle").textContent          = "DID";
    document.getElementById("field-number").value                  = "";
    document.getElementById("field-number").disabled               = false;
    document.getElementById("btn-delete-did").style.display        = "none";
    openModal();
  });

  // ── Open DID modal (edit) ─────────────────────────────────────────────────
  async function openDIDModal(id) {
    currentDIDId = id;
    hideModalError();
    resetDeleteBtn();

    const r = await fetch(`/api/did/${id}`);
    if (!r.ok) return;
    const d = await r.json();

    document.getElementById("modal-title").textContent          = formatNumber(d.number);
    document.getElementById("modal-subtitle").textContent       = "DID";
    document.getElementById("field-number").value               = formatNumber(d.number);
    document.getElementById("field-number").disabled            = true;
    document.getElementById("btn-delete-did").style.display     = d.circuitId ? "none" : "";

    deselectRows();
    const row = tbody.querySelector(`.did-row[data-id="${id}"]`);
    if (row) row.classList.add("row-selected");

    const url = new URL(window.location.href);
    url.searchParams.set("modal", String(id));
    history.pushState({ modal: id }, "", url.toString());

    openModal();
  }

  // ── Sort ──────────────────────────────────────────────────────────────────
  const SORT_ASC  = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>`;
  const SORT_DESC = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>`;

  function updateSortIcons() {
    document.querySelectorAll(".sort-col").forEach(el => {
      el.querySelector("svg")?.remove();
      if (el.dataset.field === currentSortField)
        el.insertAdjacentHTML("beforeend", currentSortDirection === "asc" ? SORT_ASC : SORT_DESC);
    });
  }

  document.querySelectorAll(".sort-col[data-field]").forEach(el => {
    el.addEventListener("click", () => {
      const field = el.dataset.field;
      if (currentSortField === field) {
        currentSortDirection = currentSortDirection === "asc" ? "desc" : "asc";
      } else {
        currentSortField = field; currentSortDirection = "asc";
      }
      updateSortIcons();
      carregarDados(0);
    });
  });

  // ── Filters ───────────────────────────────────────────────────────────────
  document.querySelectorAll(".filter-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      currentFilter = btn.dataset.filter;
      document.querySelectorAll(".filter-btn").forEach(b => {
        const active = b.dataset.filter === currentFilter;
        b.classList.toggle("bg-white",       active);
        b.classList.toggle("text-[#1a1a1a]", active);
        b.classList.toggle("font-medium",    active);
        b.classList.toggle("text-[#888]",    !active);
      });
      carregarDados(0);
    });
  });

  // ── Search ────────────────────────────────────────────────────────────────
  searchInput.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => carregarDados(0), 300);
  });

  // ── Load data ─────────────────────────────────────────────────────────────
  function carregarDados(pagina) {
    tbody.innerHTML = `<div class="did-row" style="cursor:default"><span style="grid-column:1/-1;color:#aaa;font-size:13px">Carregando...</span></div>`;
    const search = encodeURIComponent(searchInput.value.trim());
    const status = currentFilter !== "all" ? `&status=${currentFilter}` : "";
    const url    = `/api/did/dids?page=${pagina}&size=20&sort=${currentSortField},${currentSortDirection}&search=${search}${status}`;

    fetch(url)
      .then(r => { if (!r.ok) throw new Error(); return r.json(); })
      .then(data => {
        currentPage = pagina;
        totalPages  = data.totalPages;
        tbody.innerHTML = "";

        if (!data.content.length) {
          tbody.innerHTML = `<div class="did-row" style="cursor:default"><span style="grid-column:1/-1;color:#aaa;font-size:13px;text-align:center">Nenhum DID encontrado.</span></div>`;
        } else {
          data.content.forEach(item => renderRow(item));
        }

        pageInfo.textContent = `Página ${currentPage + 1} de ${totalPages === 0 ? 1 : totalPages}`;
        btnPrev.disabled = currentPage === 0;
        btnNext.disabled = currentPage >= totalPages - 1;
      })
      .catch(() => {
        tbody.innerHTML = `<div class="did-row" style="cursor:default"><span style="grid-column:1/-1;color:#E24B4A;font-size:13px">Erro ao carregar dados.</span></div>`;
      });
  }

  function renderRow(item) {
    const row = document.createElement("div");
    row.className = "did-row";
    row.dataset.id = item.id;

    const inUse = item.status === "IN_USE";
    const pillBg   = inUse ? "#E1F5EE" : "#E6F1FB";
    const pillText = inUse ? "#085041"  : "#0C447C";
    const pillLabel = inUse ? "Em uso" : "Livre";
    const circuitCell = item.circuit
      ? `<span class="font-mono text-[12px] text-[#1a1a1a]">${item.circuit.code}</span>`
      : `<span style="color:#888">—</span>`;

    row.innerHTML = `
      <span class="text-[13px] font-mono text-[#1a1a1a]">${item.id}</span>
      <span class="text-[13px] font-mono text-[#1a1a1a]">${formatNumber(item.number)}</span>
      <span>
        <span style="background:${pillBg};color:${pillText};border-radius:99px;font-size:11px;padding:2px 10px;font-weight:500">${pillLabel}</span>
      </span>
      ${circuitCell}
    `;
    row.addEventListener("click", () => openDIDModal(item.id));
    tbody.appendChild(row);
  }

  function removerLinhaDaListagem(id) {
    tbody.querySelector(`.did-row[data-id="${id}"]`)?.remove();
  }

  btnPrev.addEventListener("click", () => { if (currentPage > 0) carregarDados(currentPage - 1); });
  btnNext.addEventListener("click", () => { if (currentPage < totalPages - 1) carregarDados(currentPage + 1); });

  // ── Save ──────────────────────────────────────────────────────────────────
  document.getElementById("btn-save-did").addEventListener("click", async () => {
    hideModalError();
    const isNew = !currentDIDId;

    if (isNew) {
      const digits = document.getElementById("field-number").value.replace(/\D/g, "");
      if (digits.length !== 10) {
        showModalError("O número deve ter exatamente 10 dígitos: (XX) XXXX-XXXX.");
        return;
      }
      const r = await fetch("/api/did/dids", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ number: digits }),
      });
      if (r.ok || r.status === 201) {
        closeModal();
        carregarDados(currentPage);
      } else {
        const err = await r.json().catch(() => ({}));
        showModalError(err.message || "Erro ao salvar DID.");
      }
    }
  });

  // ── Delete ────────────────────────────────────────────────────────────────
  document.getElementById("btn-delete-did").addEventListener("click", async () => {
    const btn = document.getElementById("btn-delete-did");
    if (deleteClickCount === 0) {
      deleteClickCount = 1;
      btn.textContent  = "Confirmar exclusão";
      btn.classList.add("confirm");
      deleteTimer = setTimeout(resetDeleteBtn, 3000);
    } else {
      clearTimeout(deleteTimer);
      const r = await fetch(`/api/did/${currentDIDId}`, { method: "DELETE" });
      if (r.ok || r.status === 204) {
        removerLinhaDaListagem(currentDIDId);
        closeModal();
      } else {
        const err = await r.json().catch(() => ({}));
        showModalError(err.message || "Erro ao deletar DID.");
        resetDeleteBtn();
      }
    }
  });

  function resetDeleteBtn() {
    deleteClickCount = 0;
    const btn = document.getElementById("btn-delete-did");
    btn.textContent = "Deletar";
    btn.classList.remove("confirm");
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  updateSortIcons();

  const urlParam = new URLSearchParams(window.location.search).get("modal");
  if (urlParam) {
    carregarDados(0);
    setTimeout(() => openDIDModal(Number(urlParam)), 800);
  } else {
    carregarDados(0);
  }
</script>
</Layout>
