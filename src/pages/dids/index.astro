---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
    <div class="bg-white rounded-lg shadow mb-6">
        <div class="flex items-center justify-between px-6 py-5">
            <div>
                <h1 class="page-title">DIDs</h1>
                <p class="page-subtitle">Numeração DID disponível e vínculos com circuitos</p>
            </div>
            <button id="btnAdd" class="bg-green-500 text-white text-sm font-medium px-4 py-2 rounded-md hover:bg-green-600">+ Adicionar</button>
        </div>

        <hr class="border-gray-200" />

        <div class="listing-toolbar px-6 py-3">
            <div class="listing-search">
                <input id="input-search" type="text" placeholder="Pesquisar por número..." class="listing-search-input" />
                <button id="btn-search" class="listing-search-btn" title="Pesquisar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </button>
            </div>
            <div class="listing-pagination">
                <button id="btn-prev" class="listing-page-btn">‹ Anterior</button>
                <span id="page-info" class="listing-page-info">Página 1 de 1</span>
                <button id="btn-next" class="listing-page-btn">Próxima ›</button>
            </div>
        </div>

        <div class="overflow-x-auto px-4 pb-4">

        <table id="table-dids" class="table-fixed min-w-full border border-gray-200 rounded-lg shadow-sm text-sm bg-white">
            <thead class="bg-gray-100 text-gray-900">
                <tr class="font-semibold">
                    <th class="w-1/6 px-4 py-2 text-left">ID</th>
                    <th class="w-2/6 px-4 py-2 text-left">Número</th>
                    <th class="w-1/6 px-4 py-2 text-left">Status</th>
                    <th class="w-2/6 px-4 py-2 text-left">Circuito</th>
                    <th class="w-1/6 px-4 py-2 text-left">Ações</th>
                </tr>
            </thead>
            <tbody id="tbody-dids" class="divide-y divide-gray-200">
                <tr id="loading" class="py-4 px-4 text-gray-500">
                    <td>Carregando...</td>
                </tr>
            </tbody>
        </table>
        </div>
    </div>

    <!-- Modal Overlay -->
    <div id="modalOverlay" class="hidden fixed inset-0 bg-black/50 z-40"></div>

    <!-- Modal Adicionar DID -->
    <div id="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
        <div class="bg-white rounded-lg shadow-lg w-full max-w-md">

            <div class="bg-gray-50 flex items-center justify-between px-6 py-4 border-b border-gray-200">
                <h2 class="text-lg font-semibold text-gray-800">Novo DID</h2>
                <div class="flex items-center gap-2">
                    <button id="btnSave" class="bg-green-600 text-white rounded px-4 py-2 text-sm hover:bg-green-700 transition">
                        Salvar
                    </button>
                    <button id="btnCancel" class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300 text-sm text-gray-700 transition">
                        Cancelar
                    </button>
                </div>
            </div>

            <div class="px-6 py-4">
                <div id="formMessage" class="hidden mb-4 px-4 py-2 rounded text-sm"></div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Número do DID</label>
                    <input
                        id="inputNumber"
                        type="text"
                        maxlength="15"
                        class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring focus:border-blue-300"
                        placeholder="(XX) XXXX-XXXX"
                    />
                    <p class="text-xs text-gray-400 mt-1">Formato: (XX) XXXX-XXXX</p>
                </div>
            </div>
        </div>
    </div>

<script type="module" defer>
    const tbody = document.getElementById("tbody-dids");
    const loading = document.getElementById("loading");
    const table = document.getElementById("table-dids");
    const btnPrev = document.getElementById("btn-prev");
    const btnNext = document.getElementById("btn-next");
    const pageInfo = document.getElementById("page-info");

    const modal = document.getElementById("modal");
    const modalOverlay = document.getElementById("modalOverlay");
    const inputNumber = document.getElementById("inputNumber");
    const formMessage = document.getElementById("formMessage");

    let currentPage = 0;
    let totalPages = 0;

    // === Pesquisa ===
    const searchInput = document.getElementById("input-search");
    searchInput.addEventListener("keydown", (event) => {
        if (event.key === "Enter") { currentPage = 0; carregarDados(0); }
    });
    document.getElementById("btn-search").addEventListener("click", () => {
        currentPage = 0;
        carregarDados(0);
    });

    // === Máscara (XX) XXXX-XXXX ===
    inputNumber.addEventListener("input", () => {
        let digits = inputNumber.value.replace(/\D/g, '');
        if (digits.length > 10) digits = digits.substring(0, 10);

        let formatted = '';
        if (digits.length > 0) formatted = '(' + digits.substring(0, 2);
        if (digits.length >= 2) formatted += ') ';
        if (digits.length > 2) formatted += digits.substring(2, 6);
        if (digits.length > 6) formatted += '-' + digits.substring(6, 10);

        inputNumber.value = formatted;
    });

    function formatNumber(digits) {
        if (!digits || digits.length !== 10) return digits;
        return `(${digits.substring(0, 2)}) ${digits.substring(2, 6)}-${digits.substring(6, 10)}`;
    }

    function showMessage(text, type) {
        formMessage.textContent = text;
        formMessage.classList.remove('hidden', 'bg-green-100', 'text-green-700', 'bg-red-100', 'text-red-700');
        if (type === 'success') {
            formMessage.classList.add('bg-green-100', 'text-green-700');
        } else {
            formMessage.classList.add('bg-red-100', 'text-red-700');
        }
    }

    function openModal() {
        inputNumber.value = '';
        formMessage.classList.add('hidden');
        modal.classList.remove('hidden');
        modalOverlay.classList.remove('hidden');
    }

    function closeModal() {
        modal.classList.add('hidden');
        modalOverlay.classList.add('hidden');
    }

    document.getElementById("btnAdd").addEventListener("click", openModal);
    document.getElementById("btnCancel").addEventListener("click", closeModal);
    modalOverlay.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
    });

    // === Salvar ===
    document.getElementById("btnSave").addEventListener("click", async () => {
        const digits = inputNumber.value.replace(/\D/g, '');

        if (digits.length !== 10) {
            showMessage('O número deve ter exatamente 10 dígitos: (XX) XXXX-XXXX.', 'error');
            return;
        }

        try {
            const res = await fetch('/api/did/dids', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ number: digits }),
            });

            if (res.ok || res.status === 201) {
                closeModal();
                carregarDados(currentPage);
                window.showToast('DID cadastrado com sucesso!', 'success');
            } else {
                const errorText = await res.text();
                showMessage(errorText || 'Erro ao salvar DID.', 'error');
            }
        } catch {
            showMessage('Erro ao comunicar com o servidor.', 'error');
        }
    });

    // === Excluir ===
    async function deleteDID(id) {
        if (!confirm('Tem certeza que deseja excluir este DID?')) return;

        try {
            const res = await fetch(`/api/did/${id}`, { method: 'DELETE' });

            if (res.ok || res.status === 204) {
                carregarDados(currentPage);
                window.showToast('DID excluído com sucesso!', 'success');
            } else {
                const errorText = await res.text();
                window.showToast(errorText || 'Erro ao excluir DID.', 'error');
            }
        } catch {
            window.showToast('Erro ao comunicar com o servidor.', 'error');
        }
    }

    // === Tabela ===
    function carregarDados(pagina) {
        loading.style.display = "block";

        const search = encodeURIComponent(searchInput.value.trim());
        fetch(`/api/did/dids?page=${pagina}&size=20&search=${search}`)
            .then(res => {
                if (!res.ok) throw new Error("Erro na resposta da API");
                return res.json();
            })
            .then(data => {
                loading.style.display = "none";
                table.style.display = "table";

                currentPage = pagina;
                totalPages = data.totalPages;

                tbody.innerHTML = "";

                if (data.content.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-gray-500">Nenhum DID cadastrado.</td></tr>`;
                } else {
                    data.content.forEach(item => {
                        const tr = document.createElement("tr");
                        tr.className = "odd:bg-gray-50 text-gray-700";

                        const emUso = !!item.circuitId;
                        const statusLabel = emUso
                            ? `<span class="text-yellow-600 font-semibold">EM USO</span>`
                            : `<span class="text-green-600 font-semibold">LIVRE</span>`;

                        tr.innerHTML = `
                            <td class="px-4 py-2">${item.id}</td>
                            <td class="px-4 py-2 font-mono">${formatNumber(item.number)}</td>
                            <td class="px-4 py-2">${statusLabel}</td>
                            <td class="px-4 py-2 text-gray-500">${item.circuitNumber || '—'}</td>
                            <td class="px-4 py-2">
                                <button
                                    class="px-3 py-1 bg-red-600 text-white text-xs rounded hover:bg-red-700 transition disabled:opacity-50 disabled:cursor-not-allowed"
                                    data-id="${item.id}"
                                    ${emUso ? 'disabled title="DID vinculado a um circuito"' : ''}>
                                    Excluir
                                </button>
                            </td>
                        `;

                        if (!emUso) {
                            tr.querySelector('button').addEventListener('click', () => deleteDID(item.id));
                        }

                        tbody.appendChild(tr);
                    });
                }

                pageInfo.textContent = `Página ${currentPage + 1} de ${totalPages === 0 ? 1 : totalPages}`;
            })
            .catch(err => {
                loading.textContent = "Erro ao carregar dados.";
                console.error(err);
            });
    }

    btnPrev.addEventListener("click", () => {
        if (currentPage > 0) carregarDados(currentPage - 1);
    });

    btnNext.addEventListener("click", () => {
        if (currentPage < totalPages - 1) carregarDados(currentPage + 1);
    });

    carregarDados(0);
</script>
</Layout>
