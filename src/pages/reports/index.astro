---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Relatórios — AsteraComm">

  <div class="bg-white rounded-lg shadow mb-6">
    <div class="px-6 py-5">
      <h1 class="page-title">Relatórios</h1>
      <p class="page-subtitle">Geração de relatórios operacionais e financeiros</p>
    </div>

    <hr class="border-gray-200" />

    <div class="px-6 pb-6 pt-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

    <a href="/reports/call-cost"
       class="bg-white rounded-lg shadow p-6 hover:shadow-md hover:border-indigo-300 border border-transparent transition group">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-lg bg-indigo-100 flex items-center justify-center">
          <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="text-base font-semibold text-gray-800 group-hover:text-indigo-600 transition">
          Custo por Circuito
        </h2>
      </div>
      <p class="text-sm text-gray-500">
        Total de ligações, minutos consumidos e custo gerado por cada circuito em um mês/ano selecionado.
      </p>
    </a>

    </div>
    </div>
  </div>

</Layout>
