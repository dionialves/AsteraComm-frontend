---
import Layout from "../../layouts/Layout.astro";
---

<style is:global>
  .trunk-row {
    display: grid;
    grid-template-columns: minmax(0,1fr) minmax(0,1.5fr) minmax(0,1fr) 130px;
    gap: 8px;
    padding: 14px 16px;
    align-items: center;
    cursor: pointer;
    background: #ffffff;
    border-bottom: 1px solid #f0f0f0;
    transition: background 0.1s;
  }
  .trunk-row:last-child { border-bottom: none; }
  .trunk-row:hover { background: #fafafa; }
  .trunk-row.row-selected { background: #E6F1FB !important; border-left: 2px solid #378ADD; }

  .modal-trunk {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    opacity: 0; pointer-events: none;
    width: 780px;
    background: #fff; border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
    z-index: 15;
    display: flex; flex-direction: column;
    transition: transform 250ms cubic-bezier(0.4,0,0.2,1), opacity 250ms cubic-bezier(0.4,0,0.2,1);
  }
  .modal-trunk.open {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1; pointer-events: auto;
  }
</style>

<Layout>
  <!-- ── Header ──────────────────────────────────────────────────────────── -->
  <div class="flex items-start justify-between mb-5">
    <div>
      <h1 class="text-[22px] font-medium text-[#1a1a1a]">Troncos</h1>
      <p class="text-[13px] text-[#888] mt-0.5">Conexões SIP com operadoras de telefonia</p>
    </div>
    <button id="btnAdd" class="flex items-center gap-1.5 bg-[#1D9E75] text-white text-[13px] font-medium px-3 py-[9px] rounded-md hover:opacity-90 transition-opacity">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Novo tronco
    </button>
  </div>

  <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
  <div class="flex items-center justify-between mb-3 gap-3 flex-wrap">
    <div class="relative w-[280px]">
      <svg class="absolute left-[10px] top-1/2 -translate-y-1/2 pointer-events-none text-[#aaa]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input id="input-search" type="text" placeholder="Buscar por nome, host ou usuário..." class="w-full pl-[34px] pr-3 py-[9px] text-[13px] border border-[#e0e0e0] rounded-md outline-none text-[#1a1a1a] placeholder:text-[#aaa] bg-white" />
    </div>

    <!-- Pagination — hidden when totalPages <= 1 -->
    <div id="pagination-area" style="display:none" class="flex items-center gap-2">
      <button id="btn-prev" class="flex items-center justify-center w-7 h-7 rounded border border-[#e0e0e0] text-[#888] hover:bg-[#f5f5f5] transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <span id="page-info" class="text-[12px] text-[#888] whitespace-nowrap">Página 1 de 1</span>
      <button id="btn-next" class="flex items-center justify-center w-7 h-7 rounded border border-[#e0e0e0] text-[#888] hover:bg-[#f5f5f5] transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>

  <!-- ── Table ───────────────────────────────────────────────────────────── -->
  <div class="rounded-xl border border-[#e0e0e0] overflow-hidden">
    <div class="trunk-row bg-[#f5f5f5] border-b border-[#e0e0e0]" style="cursor:default">
      <span class="text-[11px] font-medium text-[#888] uppercase tracking-wide">Nome</span>
      <span class="text-[11px] font-medium text-[#888] uppercase tracking-wide">Host</span>
      <span class="text-[11px] font-medium text-[#888] uppercase tracking-wide">Usuário</span>
      <span class="text-[11px] font-medium text-[#888] uppercase tracking-wide">Registro</span>
    </div>
    <div id="tbody-trunks"></div>
  </div>

  <!-- ── Footer counter ─────────────────────────────────────────────────── -->
  <p id="counter" class="text-[12px] text-[#888] text-right mt-3"></p>

  <!-- ── Overlay ────────────────────────────────────────────────────────── -->
  <div id="modal-overlay-1" class="modal-overlay"></div>

  <!-- ── Modal Tronco ───────────────────────────────────────────────────── -->
  <div id="modal-trunk" class="modal-trunk">

    <div class="modal-header">
      <div class="modal-header-top">
        <div class="modal-header-titles">
          <span class="modal-subtitle">Tronco</span>
          <span id="modal-title" class="modal-title">Novo Tronco</span>
        </div>
        <button id="btnClose" class="modal-btn-close" title="Fechar">✕</button>
      </div>
    </div>

    <div id="modal-error" class="modal-error"></div>

    <div class="modal-body">

      <p class="section-title">Identificação</p>
      <div class="form-group" style="margin-bottom:16px">
        <label class="form-label">Nome <span style="color:#ef4444">*</span></label>
        <input id="inputName" type="text" maxlength="50" placeholder="Ex: operadora-a" class="form-input" />
      </div>

      <hr class="section-divider" />
      <p class="section-title">Conexão SIP</p>

      <div class="form-group" style="margin-bottom:12px">
        <label class="form-label">Host / Domínio SIP <span style="color:#ef4444">*</span></label>
        <input id="inputHost" type="text" maxlength="255" placeholder="Ex: sip.operadora.com.br" class="form-input" style="font-family:monospace;font-size:12px" />
      </div>

      <div class="form-grid-2">
        <div class="form-group">
          <label class="form-label">Usuário <span style="color:#ef4444">*</span></label>
          <input id="inputUsername" type="text" maxlength="100" placeholder="Usuário SIP" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label">Senha <span style="color:#ef4444">*</span></label>
          <div class="input-password-wrap">
            <input id="inputPassword" type="password" maxlength="100" placeholder="••••••••" class="form-input" autocomplete="new-password" />
            <button id="btn-toggle-pw" class="btn-eye" type="button" title="Ver senha">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <hr class="section-divider" />
      <p class="section-title">Configuração</p>

      <div class="form-group">
        <label class="form-label">Prefixo de discagem</label>
        <input id="inputPrefix" type="text" maxlength="20" placeholder="Ex: 8712 (opcional)" class="form-input" />
        <span style="font-size:11px;color:#aaa;margin-top:4px;display:block">Adicionado antes do número discado. Deixe em branco se não usar.</span>
      </div>

    </div>

    <div class="modal-footer">
      <button id="btnDelete" class="btn-modal-delete" style="display:none">Excluir</button>
      <div class="modal-footer-right">
        <button id="btnCancel" class="btn-modal-cancel">Cancelar</button>
        <button id="btnSave"   class="btn-modal-save">Salvar</button>
      </div>
    </div>

  </div>

<script type="module" defer>
  // ── DOM refs ──────────────────────────────────────────────────────────────
  const tbody          = document.getElementById('tbody-trunks');
  const counter        = document.getElementById('counter');
  const inputSearch    = document.getElementById('input-search');
  const paginationArea = document.getElementById('pagination-area');
  const btnPrev        = document.getElementById('btn-prev');
  const btnNext        = document.getElementById('btn-next');
  const pageInfo       = document.getElementById('page-info');

  const overlay        = document.getElementById('modal-overlay-1');
  const modalTrunk     = document.getElementById('modal-trunk');
  const modalTitle     = document.getElementById('modal-title');
  const modalError     = document.getElementById('modal-error');
  const inputName      = document.getElementById('inputName');
  const inputHost      = document.getElementById('inputHost');
  const inputUsername  = document.getElementById('inputUsername');
  const inputPassword  = document.getElementById('inputPassword');
  const inputPrefix    = document.getElementById('inputPrefix');
  const btnDelete      = document.getElementById('btnDelete');

  // ── State ─────────────────────────────────────────────────────────────────
  let currentPage      = 0;
  let totalPages       = 0;
  let totalElements    = 0;
  let editingTrunkName = null;
  let selectedRow      = null;
  let debounceTimer    = null;
  let deleteClickCount = 0;
  let deleteTimer      = null;

  // ── Search debounce ───────────────────────────────────────────────────────
  inputSearch.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => loadTrunks(0), 300);
  });

  // ── Pagination ────────────────────────────────────────────────────────────
  btnPrev.addEventListener('click', () => { if (currentPage > 0) loadTrunks(currentPage - 1); });
  btnNext.addEventListener('click', () => { if (currentPage < totalPages - 1) loadTrunks(currentPage + 1); });

  // ── Password toggle ───────────────────────────────────────────────────────
  document.getElementById('btn-toggle-pw').addEventListener('click', () => {
    inputPassword.type = inputPassword.type === 'password' ? 'text' : 'password';
  });

  // ── Load data ─────────────────────────────────────────────────────────────
  function loadTrunks(page) {
    const search = encodeURIComponent(inputSearch.value.trim());
    const url = `/api/trunk/trunks?page=${page}&size=20&sort=name,asc&search=${search}`;

    tbody.innerHTML = `<div class="trunk-row" style="cursor:default"><span style="font-size:13px;color:#aaa">Carregando...</span></div>`;

    fetch(url)
      .then(r => { if (!r.ok) throw new Error(); return r.json(); })
      .then(data => {
        currentPage   = page;
        totalPages    = data.totalPages;
        totalElements = data.totalElements;
        renderTable(data.content);
        renderCounter();
        renderPagination();
      })
      .catch(() => {
        tbody.innerHTML = `<div class="trunk-row" style="cursor:default"><span style="font-size:13px;color:#888">Erro ao carregar dados.</span></div>`;
      });
  }

  // ── Render table ──────────────────────────────────────────────────────────
  function renderTable(items) {
    if (items.length === 0) {
      tbody.innerHTML = `<div class="trunk-row" style="cursor:default"><span style="font-size:13px;color:#888">Nenhum tronco cadastrado.</span></div>`;
      return;
    }
    tbody.innerHTML = '';
    items.forEach(item => {
      const row = document.createElement('div');
      row.className = 'trunk-row';
      row.dataset.name = item.name;

      const badge = item.registered
        ? `<span style="background:#E1F5EE;color:#085041;border-radius:99px;font-size:11px;padding:2px 10px;font-weight:500">Registrado</span>`
        : `<span style="background:#FCEBEB;color:#791F1F;border-radius:99px;font-size:11px;padding:2px 10px;font-weight:500">Não registrado</span>`;

      row.innerHTML = `
        <span style="font-size:13px;font-weight:500;color:#1a1a1a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${item.name}</span>
        <span style="font-size:12px;font-family:monospace;color:#1a1a1a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${item.host}</span>
        <span style="font-size:13px;color:#1a1a1a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${item.username}</span>
        <span>${badge}</span>
      `;
      row.addEventListener('click', () => openModal(item.name, row));
      tbody.appendChild(row);
    });
  }

  // ── Render counter ────────────────────────────────────────────────────────
  function renderCounter() {
    counter.textContent = totalElements === 1
      ? '1 tronco cadastrado'
      : `${totalElements} troncos cadastrados`;
  }

  // ── Render pagination ─────────────────────────────────────────────────────
  function renderPagination() {
    if (totalPages <= 1) {
      paginationArea.style.display = 'none';
      return;
    }
    paginationArea.style.display = 'flex';
    pageInfo.textContent = `Página ${currentPage + 1} de ${totalPages}`;
    btnPrev.disabled = currentPage === 0;
    btnNext.disabled = currentPage >= totalPages - 1;
  }

  // ── Modal open ────────────────────────────────────────────────────────────
  function openModal(trunkName, row) {
    editingTrunkName = trunkName || null;
    const isEdit = !!editingTrunkName;

    inputName.value     = '';
    inputHost.value     = '';
    inputUsername.value = '';
    inputPassword.value = '';
    inputPrefix.value   = '';
    hideError();

    modalTitle.textContent = isEdit ? editingTrunkName : 'Novo Tronco';

    if (isEdit) {
      inputName.value    = editingTrunkName;
      inputName.disabled = true;
      btnDelete.style.display = '';

      if (selectedRow) selectedRow.classList.remove('row-selected');
      selectedRow = row;
      if (selectedRow) selectedRow.classList.add('row-selected');

      fetch(`/api/trunk/${editingTrunkName}`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (data) {
            inputHost.value     = data.host     || '';
            inputUsername.value = data.username || '';
            inputPassword.value = data.password || '';
            inputPrefix.value   = data.prefix   || '';
          }
        })
        .catch(() => {});
    } else {
      inputName.disabled = false;
      btnDelete.style.display = 'none';
    }

    overlay.classList.add('active');
    modalTrunk.classList.add('open');
  }

  // ── Modal close ───────────────────────────────────────────────────────────
  function closeModal() {
    overlay.classList.remove('active');
    modalTrunk.classList.remove('open');
    editingTrunkName = null;
    if (selectedRow) { selectedRow.classList.remove('row-selected'); selectedRow = null; }
    clearTimeout(deleteTimer);
    resetDeleteBtn();
  }

  // ── Error helpers ─────────────────────────────────────────────────────────
  function showError(text) {
    modalError.textContent = text;
    modalError.style.display = 'block';
  }
  function hideError() {
    modalError.style.display = 'none';
    modalError.textContent   = '';
  }

  // ── Event listeners ───────────────────────────────────────────────────────
  document.getElementById('btnAdd').addEventListener('click', () => openModal(null, null));
  document.getElementById('btnClose').addEventListener('click', closeModal);
  document.getElementById('btnCancel').addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && modalTrunk.classList.contains('open')) closeModal();
  });

  // ── Save ──────────────────────────────────────────────────────────────────
  document.getElementById('btnSave').addEventListener('click', async () => {
    const name     = inputName.value.trim();
    const host     = inputHost.value.trim();
    const username = inputUsername.value.trim();
    const password = inputPassword.value;
    const prefix   = inputPrefix.value.trim() || null;
    const isEdit   = !!editingTrunkName;

    if (!name)     { showError('O nome é obrigatório.');    return; }
    if (!host)     { showError('O host é obrigatório.');    return; }
    if (!username) { showError('O usuário é obrigatório.'); return; }
    if (!isEdit && !password) { showError('A senha é obrigatória.'); return; }

    try {
      const res = isEdit
        ? await fetch(`/api/trunk/${editingTrunkName}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: editingTrunkName, host, username, password, prefix }),
          })
        : await fetch('/api/trunk/trunks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, host, username, password, prefix }),
          });

      if (res.ok || res.status === 201) {
        closeModal();
        loadTrunks(currentPage);
        window.showToast(isEdit ? 'Tronco atualizado com sucesso!' : 'Tronco criado com sucesso!', 'success');
      } else {
        const err = await res.text();
        showError(err || 'Erro ao salvar tronco.');
      }
    } catch {
      showError('Erro ao comunicar com o servidor.');
    }
  });

  // ── Delete (dois cliques) ─────────────────────────────────────────────────
  btnDelete.addEventListener('click', async () => {
    if (!editingTrunkName) return;

    if (deleteClickCount === 0) {
      deleteClickCount = 1;
      btnDelete.textContent = 'Confirmar exclusão';
      btnDelete.classList.add('confirm');
      deleteTimer = setTimeout(resetDeleteBtn, 3000);
      return;
    }

    clearTimeout(deleteTimer);
    try {
      const res = await fetch(`/api/trunk/${editingTrunkName}`, { method: 'DELETE' });
      if (res.ok || res.status === 204) {
        closeModal();
        loadTrunks(currentPage);
        window.showToast('Tronco excluído com sucesso!', 'success');
      } else {
        resetDeleteBtn();
        showError('Erro ao excluir tronco.');
      }
    } catch {
      resetDeleteBtn();
      showError('Erro ao comunicar com o servidor.');
    }
  });

  function resetDeleteBtn() {
    deleteClickCount = 0;
    btnDelete.textContent = 'Excluir';
    btnDelete.classList.remove('confirm');
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  loadTrunks(0);
</script>
</Layout>
