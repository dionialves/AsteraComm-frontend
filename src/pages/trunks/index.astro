---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
    <div class="bg-white rounded-lg shadow mb-6">
        <div class="flex items-center justify-between px-6 py-5">
            <div>
                <h1 class="page-title">Troncos</h1>
                <p class="page-subtitle">Conexões SIP com operadoras de telefonia</p>
            </div>
            <button id="btnAdd" class="bg-green-600 text-white text-sm font-medium px-4 py-2 rounded-md hover:bg-green-700">+ Adicionar</button>
        </div>

        <hr class="border-gray-200" />

        <div class="listing-toolbar px-6 py-3">
            <div class="listing-search">
                <input id="input-search" type="text" placeholder="Pesquisar por nome, host ou usuário..." class="listing-search-input" />
                <button id="btn-search" class="listing-search-btn" title="Pesquisar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </button>
            </div>
            <div class="listing-pagination">
                <button id="btn-prev" class="listing-page-btn">‹ Anterior</button>
                <span id="page-info" class="listing-page-info">Página 1 de 1</span>
                <button id="btn-next" class="listing-page-btn">Próxima ›</button>
            </div>
        </div>

        <div class="overflow-x-auto px-4 pb-4">

        <table id="table-trunks" class="table-fixed min-w-full border border-gray-200 rounded-lg shadow-sm text-sm bg-white">
            <thead class="bg-gray-100 text-gray-900">
                <tr class="font-semibold">
                    <th data-field="name" class="w-1/4 px-4 py-2 text-left font-semibold cursor-pointer">Nome</th>
                    <th data-field="host" class="w-1/4 px-4 py-2 text-left font-semibold cursor-pointer">Host</th>
                    <th data-field="username" class="w-1/4 px-4 py-2 text-left font-semibold cursor-pointer">Usuário</th>
                    <th data-field="registered" class="w-1/4 px-4 py-2 text-left font-semibold cursor-pointer">Registro</th>
                </tr>
            </thead>
            <tbody id="tbody-trunks" class="divide-y divide-gray-200">
                <tr id="loading" class="py-4 px-4 text-gray-500">
                    <td>Carregando...</td>
                </tr>
            </tbody>
        </table>
        </div>
    </div>

    <!-- Modal Overlay -->
    <div id="modalOverlay" class="hidden fixed inset-0 bg-black/50 z-40"></div>

    <!-- Modal Criar/Editar -->
    <div id="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
        <div class="bg-white rounded-lg shadow-lg w-full max-w-lg">

            <!-- Header do Modal -->
            <div class="bg-gray-50 flex items-center justify-between px-6 py-4 border-b border-gray-200">
                <h2 id="modalTitle" class="text-lg font-semibold text-gray-800">Novo Tronco</h2>
                <div class="flex items-center gap-2">
                    <button id="btnSave" class="bg-green-600 text-white rounded px-4 py-2 text-sm hover:bg-green-700 transition">
                        Salvar
                    </button>
                    <button id="btnDelete" class="hidden bg-red-600 text-white rounded px-4 py-2 text-sm hover:bg-red-700 transition">
                        Excluir
                    </button>
                    <button id="btnCancel" class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300 text-sm text-gray-700 transition">
                        Cancelar
                    </button>
                </div>
            </div>

            <!-- Body do Modal -->
            <div class="px-6 py-4">
                <div id="formMessage" class="hidden mb-4 px-4 py-2 rounded text-sm"></div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nome <span class="text-red-500">*</span></label>
                        <input
                            id="inputName"
                            type="text"
                            maxlength="50"
                            class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring focus:border-blue-300"
                            placeholder="Ex: operadora-a"
                        />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Host / Domínio SIP <span class="text-red-500">*</span></label>
                        <input
                            id="inputHost"
                            type="text"
                            maxlength="255"
                            class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring focus:border-blue-300"
                            placeholder="Ex: sip.operadora.com.br"
                        />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Usuário <span class="text-red-500">*</span></label>
                        <input
                            id="inputUsername"
                            type="text"
                            maxlength="100"
                            class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring focus:border-blue-300"
                            placeholder="Usuário SIP"
                        />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Senha <span class="text-red-500">*</span></label>
                        <input
                            id="inputPassword"
                            type="password"
                            maxlength="100"
                            class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring focus:border-blue-300"
                            placeholder="Deixe em branco para não alterar"
                        />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Prefixo de discagem</label>
                        <input
                            id="inputPrefix"
                            type="text"
                            maxlength="20"
                            class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring focus:border-blue-300"
                            placeholder="Ex: 8712 (opcional)"
                        />
                        <p class="text-xs text-gray-400 mt-1">Adicionado antes do número discado. Deixe em branco se não usar.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

<script type="module" defer>
    const tbody = document.getElementById("tbody-trunks");
    const loading = document.getElementById("loading");
    const table = document.getElementById("table-trunks");
    const btnPrev = document.getElementById("btn-prev");
    const btnNext = document.getElementById("btn-next");
    const pageInfo = document.getElementById("page-info");

    const modal = document.getElementById("modal");
    const modalOverlay = document.getElementById("modalOverlay");
    const modalTitle = document.getElementById("modalTitle");
    const inputName = document.getElementById("inputName");
    const inputHost = document.getElementById("inputHost");
    const inputUsername = document.getElementById("inputUsername");
    const inputPassword = document.getElementById("inputPassword");
    const inputPrefix = document.getElementById("inputPrefix");
    const formMessage = document.getElementById("formMessage");
    const btnDelete = document.getElementById("btnDelete");

    let currentPage = 0;
    let totalPages = 0;
    let currentSortField = "name";
    let currentSortDirection = "asc";
    let editingTrunkName = null;

    // === Ordenação ===
    document.querySelectorAll("thead th[data-field]").forEach(th => {
        th.addEventListener("click", () => {
            const field = th.getAttribute("data-field");
            if (currentSortField === field) {
                currentSortDirection = currentSortDirection === "asc" ? "desc" : "asc";
            } else {
                currentSortField = field;
                currentSortDirection = "asc";
            }
            carregarDados(0);
        });
    });

    // === Pesquisa ===
    document.getElementById("input-search").addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
            currentPage = 0;
            carregarDados(0);
        }
    });
    document.getElementById("btn-search").addEventListener("click", () => {
        currentPage = 0;
        carregarDados(0);
    });

    // === Auxiliares ===
    function showMessage(text, type) {
        formMessage.textContent = text;
        formMessage.classList.remove('hidden', 'bg-green-100', 'text-green-700', 'bg-red-100', 'text-red-700');
        formMessage.classList.add(type === 'success' ? 'bg-green-100' : 'bg-red-100');
        formMessage.classList.add(type === 'success' ? 'text-green-700' : 'text-red-700');
    }

    // === Modal ===
    function openModal(trunkName) {
        editingTrunkName = trunkName || null;
        const isEdit = !!editingTrunkName;

        inputName.value = '';
        inputHost.value = '';
        inputUsername.value = '';
        inputPassword.value = '';
        inputPrefix.value = '';
        formMessage.classList.add('hidden');

        modalTitle.textContent = isEdit ? 'Editar Tronco' : 'Novo Tronco';

        if (isEdit) {
            inputName.value = editingTrunkName;
            inputName.readOnly = true;
            inputName.classList.add('bg-gray-100', 'cursor-not-allowed');
            btnDelete.classList.remove('hidden');

            fetch(`/api/trunk/${editingTrunkName}`)
                .then(r => r.ok ? r.json() : null)
                .then(data => {
                    if (data) {
                        inputHost.value = data.host || '';
                        inputUsername.value = data.username || '';
                        inputPrefix.value = data.prefix || '';
                    }
                })
                .catch(() => {});
        } else {
            inputName.readOnly = false;
            inputName.classList.remove('bg-gray-100', 'cursor-not-allowed');
            btnDelete.classList.add('hidden');
        }

        modal.classList.remove('hidden');
        modalOverlay.classList.remove('hidden');
    }

    function closeModal() {
        modal.classList.add('hidden');
        modalOverlay.classList.add('hidden');
        editingTrunkName = null;
    }

    document.getElementById("btnAdd").addEventListener("click", () => openModal(null));
    document.getElementById("btnCancel").addEventListener("click", closeModal);
    modalOverlay.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
    });

    // === Salvar ===
    document.getElementById("btnSave").addEventListener("click", async () => {
        const name = inputName.value.trim();
        const host = inputHost.value.trim();
        const username = inputUsername.value.trim();
        const password = inputPassword.value;
        const prefix = inputPrefix.value.trim() || null;
        const isEdit = !!editingTrunkName;

        if (!name) { showMessage('O nome é obrigatório.', 'error'); return; }
        if (!host) { showMessage('O host é obrigatório.', 'error'); return; }
        if (!username) { showMessage('O usuário é obrigatório.', 'error'); return; }
        if (!isEdit && !password) { showMessage('A senha é obrigatória.', 'error'); return; }

        try {
            let res;
            if (isEdit) {
                res = await fetch(`/api/trunk/${editingTrunkName}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name: editingTrunkName, host, username, password, prefix }),
                });
            } else {
                res = await fetch('/api/trunk/trunks', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, host, username, password, prefix }),
                });
            }

            if (res.ok || res.status === 201) {
                closeModal();
                carregarDados(currentPage);
                window.showToast(isEdit ? 'Tronco atualizado com sucesso!' : 'Tronco criado com sucesso!', 'success');
            } else {
                const errorText = await res.text();
                showMessage(errorText || 'Erro ao salvar tronco.', 'error');
            }
        } catch {
            showMessage('Erro ao comunicar com o servidor.', 'error');
        }
    });

    // === Excluir ===
    btnDelete.addEventListener("click", async () => {
        if (!editingTrunkName) return;
        if (!confirm('Tem certeza que deseja excluir este tronco?')) return;

        try {
            const res = await fetch(`/api/trunk/${editingTrunkName}`, { method: 'DELETE' });

            if (res.ok || res.status === 204) {
                closeModal();
                carregarDados(currentPage);
                window.showToast('Tronco excluído com sucesso!', 'success');
            } else {
                showMessage('Erro ao excluir tronco.', 'error');
            }
        } catch {
            showMessage('Erro ao comunicar com o servidor.', 'error');
        }
    });

    // === Tabela ===
    function carregarDados(pagina) {
        loading.style.display = "block";
        table.style.visibility = "visible";

        const termoPesquisa = encodeURIComponent(document.getElementById("input-search").value.trim());
        const url = `/api/trunk/trunks?page=${pagina}&size=20&sort=${currentSortField},${currentSortDirection}&search=${termoPesquisa}`;

        fetch(url)
            .then(res => {
                if (!res.ok) throw new Error("Erro na resposta da API");
                return res.json();
            })
            .then(data => {
                loading.style.display = "none";
                table.style.display = "table";

                currentPage = pagina;
                totalPages = data.totalPages;

                tbody.innerHTML = "";

                if (data.content.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="4" class="text-center py-4 text-gray-500">Nenhum tronco cadastrado.</td></tr>`;
                } else {
                    data.content.forEach(item => {
                        const tr = document.createElement("tr");
                        tr.className = "odd:bg-gray-50 text-gray-700 hover:bg-gray-100 transition-colors cursor-pointer";

                        tr.innerHTML = `
                            <td class="px-4 py-2 font-medium">${item.name}</td>
                            <td class="px-4 py-2 text-gray-500">${item.host}</td>
                            <td class="px-4 py-2 text-gray-500">${item.username}</td>
                            <td class="px-4 py-2 font-semibold ${item.registered ? 'text-green-600' : 'text-red-600'}">
                                ${item.registered ? 'Registrado' : 'Não registrado'}
                            </td>
                        `;

                        tr.addEventListener('click', () => openModal(item.name));
                        tbody.appendChild(tr);
                    });
                }

                pageInfo.textContent = `Página ${currentPage + 1} de ${totalPages === 0 ? 1 : totalPages}`;
            })
            .catch(err => {
                loading.textContent = "Erro ao carregar dados.";
                console.error(err);
            });
    }

    btnPrev.addEventListener("click", () => { if (currentPage > 0) carregarDados(currentPage - 1); });
    btnNext.addEventListener("click", () => { if (currentPage < totalPages - 1) carregarDados(currentPage + 1); });

    carregarDados(0);
</script>
</Layout>
